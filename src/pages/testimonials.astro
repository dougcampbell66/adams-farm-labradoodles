---
import Layout from '../layouts/Layout.astro';
import { getCollection } from 'astro:content';

const allTestimonials = await getCollection('testimonials');
const featured = allTestimonials.find(t => t.data.featured);
const rest = allTestimonials.filter(t => !t.data.featured);
---
<Layout title="Testimonials" description="What families say about their Adams Farm Labradoodle puppies.">
  <div class="page-hero">
    <div class="container">
      <p class="eyebrow">From our forever families</p>
      <h1>What Families Are Saying</h1>
    </div>
  </div>

  {featured && (
    <section class="featured-section">
      <div class="container featured-inner">
        <p class="featured-quote">&ldquo;{featured.data.quote}&rdquo;</p>
        <p class="featured-attr">&mdash; {featured.data.family}{featured.data.year ? `, ${featured.data.year}` : ''}</p>
      </div>
    </section>
  )}

  <section class="section">
    <div class="container">
      <div class="t-grid">
        {rest.map(t => (
          <div class="t-card">
            <p class="t-quote">&ldquo;{t.data.quote}&rdquo;</p>
            <p class="t-attr">&mdash; {t.data.family}{t.data.year ? `, ${t.data.year}` : ''}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <section class="t-cta">
    <div class="container t-cta-inner">
      <div>
        <p class="eyebrow">Ready to join them?</p>
        <h2 class="t-cta-heading">Reserve Your Adams Farm Puppy</h2>
      </div>
      <a href="/contact" class="btn btn-primary">Apply Now</a>
    </div>
  </section>
</Layout>

<style>
  .featured-section {
    background: var(--color-pine);
    padding: 72px 0;
  }
  .featured-inner {
    max-width: 760px;
  }
  .featured-quote {
    font-family: var(--font-display);
    font-style: italic;
    font-size: clamp(1.15rem, 2.5vw, 1.5rem);
    color: var(--color-card);
    line-height: 1.6;
    margin: 0 0 20px;
  }
  .featured-attr {
    font-size: 0.78rem;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    color: rgba(237,227,208,0.55);
    margin: 0;
  }

  .t-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 20px;
  }
  .t-card {
    background: var(--color-card);
    border-radius: 10px;
    padding: 26px 24px 22px;
    display: flex;
    flex-direction: column;
    gap: 14px;
  }
  .t-quote {
    font-family: var(--font-display);
    font-style: italic;
    font-size: 0.97rem;
    color: var(--color-pine);
    line-height: 1.7;
    margin: 0;
    flex: 1;
  }
  .t-attr {
    font-size: 0.74rem;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    color: var(--color-brass);
    margin: 0;
  }

  .t-cta {
    background: var(--color-charcoal-bg);
    border-top: 1px solid var(--color-border-dark);
    padding: 56px 0;
  }
  .t-cta-inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 32px;
  }
  .t-cta .eyebrow { margin-bottom: 6px; }
  .t-cta-heading { margin: 0; }

  @media (max-width: 768px) {
    .t-grid { grid-template-columns: 1fr; }
    .t-cta-inner { flex-direction: column; align-items: flex-start; }
  }
</style>

