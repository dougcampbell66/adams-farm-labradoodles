---
import Layout from '../layouts/Layout.astro';
import { getCollection } from 'astro:content';

const dogs = await getCollection('dogs');
const active = dogs.filter((d) => d.data.status !== 'retired');
const retired = dogs.filter((d) => d.data.status === 'retired');
---
<Layout title="Our dogs">
  <section class="section container">
    <p class="eyebrow">Health tested &middot; ALAA accredited</p>
    <h1>Our dogs</h1>

    <h2 class="section-heading">Current breeding dogs</h2>
    <div class="dog-grid">
      {active.map((dog) => (
        <a href={`/dogs/${dog.slug}`} class="card dog-card">
          {dog.data.photo && (
            <img src={dog.data.photo} alt={dog.data.name} class="card-photo" />
          )}
          <div class="card-body">
            <h3>{dog.data.name} <span class="role">({dog.data.role})</span></h3>
            {dog.data.registeredName && <p class="detail">{dog.data.registeredName} &middot; {dog.data.regNumber}</p>}
            {dog.data.coi && (
              <p class="coi">
                COI: {dog.data.coi}
                <span class="coi-caption">Lower COI means greater genetic diversity.</span>
              </p>
            )}
            <p class="desc">{dog.data.description}</p>
            <span class="profile-link">View full profile &rarr;</span>
          </div>
        </a>
      ))}
    </div>

    {retired.length > 0 && (
      <>
        <h2 class="section-heading retired-heading">Retired</h2>
        <div class="dog-grid">
          {retired.map((dog) => (
            <a href={`/dogs/${dog.slug}`} class="card dog-card retired-card">
              {dog.data.photo && (
                <img src={dog.data.photo} alt={dog.data.name} class="card-photo" />
              )}
              <div class="card-body">
                <h3>{dog.data.name} <span class="role">({dog.data.role})</span></h3>
                {dog.data.registeredName && <p class="detail">{dog.data.registeredName} &middot; {dog.data.regNumber}</p>}
                {dog.data.coi && (
                  <p class="coi">
                    COI: {dog.data.coi}
                    <span class="coi-caption">Lower COI means greater genetic diversity.</span>
                  </p>
                )}
                <p class="desc">{dog.data.description}</p>
                <span class="profile-link">View full profile &rarr;</span>
              </div>
            </a>
          ))}
        </div>
      </>
    )}
  </section>
</Layout>

<style>
  .section-heading {
    margin-top: 36px;
    margin-bottom: 16px;
    font-size: 1.1rem;
    letter-spacing: 0.04em;
    text-transform: uppercase;
    color: var(--color-muted);
  }
  .retired-heading {
    margin-top: 48px;
  }
  .dog-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 20px;
  }
  .dog-card {
    display: flex;
    flex-direction: column;
    text-decoration: none;
    color: inherit;
    transition: box-shadow 0.15s;
  }
  .dog-card:hover {
    box-shadow: 0 4px 20px rgba(0,0,0,0.10);
  }
  .card-photo {
    width: 100%;
    height: 220px;
    object-fit: contain;
    background: var(--color-card);
    border-radius: 8px 8px 0 0;
    display: block;
  }
  .card-body {
    padding: 16px;
    flex: 1;
    display: flex;
    flex-direction: column;
  }
  .retired-card {
    opacity: 0.75;
  }
  .role {
    font-size: 0.9rem;
    color: var(--color-muted);
    font-style: italic;
  }
  .detail {
    color: var(--color-mustard);
    font-size: 0.8rem;
    margin: 4px 0;
  }
  .coi {
    font-size: 0.78rem;
    margin: 6px 0 2px;
    color: var(--color-pine);
  }
  .coi-caption {
    display: block;
    font-size: 0.7rem;
    color: var(--color-muted);
    margin-top: 1px;
  }
  .desc {
    font-size: 0.9rem;
    margin-top: 8px;
    flex: 1;
  }
  .profile-link {
    display: inline-block;
    margin-top: 12px;
    font-size: 0.8rem;
    color: var(--color-pine);
    font-weight: 600;
  }
  @media (max-width: 640px) {
    .dog-grid { grid-template-columns: 1fr; }
  }
</style>
