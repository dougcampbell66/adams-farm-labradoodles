---
import Layout from '../layouts/Layout.astro';
import { getCollection } from 'astro:content';

const allPuppies = await getCollection('puppies');
const springPuppies = allPuppies
  .filter(p => p.data.litter === 'spring-2026')
  .sort((a, b) => (a.data.order ?? 99) - (b.data.order ?? 99));
---
<Layout title="Home">

  <!-- ─── HERO (unchanged) ─────────────────────────────────────── -->
  <svg width="0" height="0" style="position:absolute;pointer-events:none" aria-hidden="true">
    <defs>
      <clipPath id="hero-blob" clipPathUnits="objectBoundingBox">
        <path d="M 0.53,0.02 C 0.79,0.00 0.99,0.22 0.97,0.52 C 0.96,0.79 0.77,0.98 0.50,0.97 C 0.23,0.96 0.02,0.77 0.03,0.50 C 0.04,0.23 0.25,0.03 0.53,0.02 Z"/>
      </clipPath>
    </defs>
  </svg>

  <section class="hero-section">
    <div class="hero-bg" aria-hidden="true">
      <div class="bg-blob bb-mustard-tr"></div>
      <div class="bg-blob bb-pine-bl"></div>
    </div>
    <div class="container hero-grid">
      <div class="hero-text">
        <p class="eyebrow">Australian Labradoodles</p>
        <h1>Raised in Loving Homes. Ready for Yours.</h1>
        <p class="hero-copy">Every litter comes from fully health-tested parents and grows up surrounded by family, before going to yours.</p>
        <div class="hero-actions">
          <a href="/puppies" class="btn btn-primary">See available puppies</a>
          <a href="/our-dogs" class="btn btn-secondary">Meet the parents</a>
        </div>
      </div>
      <div class="hero-photo-frame">
        <div class="hero-photo-masked">
          <img
            src="/images/hero/founder-hero-portrait.jpg"
            alt="A girl holding an Adams Farm Labradoodle puppy"
            class="hero-photo-img"
          />
        </div>
        <div class="hero-testimonial">
          <p class="ht-quote">&ldquo;We are smitten with our bright &amp; adorable Australian Labradoodle.&rdquo;</p>
          <p class="ht-attr">&mdash; Deirdre</p>
        </div>
      </div>
    </div>
  </section>

  <!-- ① PUPPIES: horizontal scroll carousel -->
  <section class="s-puppies">
    <div class="container s-puppies-hd">
      <p class="eyebrow">Available Puppies</p>
      <h2 class="puppies-heading">Meet Our Lilo &amp; Stitch May Litter</h2>
      <p class="puppies-sub">These practically perfect puppies come from Legend Manor&rsquo;s Holly and Tarheel&rsquo;s Knox, and are expected to mature into large minis between 20 and 25 lbs.</p>
      <a href="/our-dogs" class="puppies-parents-link">Meet the Parents &rarr;</a>
    </div>
    <div class="container puppies-carousel-wrap">
      <button class="carousel-btn carousel-btn-prev" id="puppy-prev" aria-label="Scroll left">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M15 18l-6-6 6-6"/></svg>
      </button>
      <div class="s-scroll" id="puppy-scroll">
        {springPuppies.map((p) => (
          <div class="puppy-card">
            <div class="puppy-card-photo">
              <img src={p.data.photo} alt={p.data.name} loading="lazy" />
            </div>
            <div class="puppy-card-body">
              <span class="puppy-name">{p.data.name}</span>
              {p.data.collar && <span class="puppy-collar">{p.data.collar}</span>}
              <div class="puppy-badges">
                {p.data.sex && <span class="puppy-sex">{p.data.sex}</span>}
                <span class={`litter-status litter-status-${p.data.status}`}>
                  {p.data.status.charAt(0).toUpperCase() + p.data.status.slice(1)}
                </span>
              </div>
            </div>
          </div>
        ))}
      </div>
      <button class="carousel-btn carousel-btn-next" id="puppy-next" aria-label="Scroll right">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M9 18l6-6-6-6"/></svg>
      </button>
    </div>
    <div class="container puppies-cta">
      <a href="/contact" class="btn btn-primary">Reserve a Puppy</a>
    </div>
  </section>

  <script>
    const track = document.getElementById('puppy-scroll') as HTMLElement | null;
    const btnPrev = document.getElementById('puppy-prev') as HTMLButtonElement | null;
    const btnNext = document.getElementById('puppy-next') as HTMLButtonElement | null;

    function updateArrows() {
      if (!track || !btnPrev || !btnNext) return;
      btnPrev.style.display = track.scrollLeft <= 1 ? 'none' : 'flex';
      btnNext.style.display = track.scrollLeft + track.clientWidth >= track.scrollWidth - 1 ? 'none' : 'flex';
    }

    function cardStep() {
      const card = track?.querySelector('.puppy-card') as HTMLElement | null;
      return card ? card.offsetWidth + 20 : 260;
    }

    btnPrev?.addEventListener('click', () => {
      track?.scrollBy({ left: -cardStep(), behavior: 'smooth' });
    });
    btnNext?.addEventListener('click', () => {
      track?.scrollBy({ left: cardStep(), behavior: 'smooth' });
    });
    track?.addEventListener('scroll', updateArrows, { passive: true });
    updateArrows();
  </script>

  <!-- ② ABOUT ADAMS FARM + ③ TRUST: image left, text + 2×2 trust grid right -->
  <section class="s-about section">
    <div class="container s-about-inner">
      <div class="about-photo">
        <img
          src="/images/story/douglas-erika-winnie.jpg"
          alt="Douglas and Erika Campbell with Winnie"
          class="about-photo-img"
        />
      </div>
      <div class="s-about-text">
        <p class="eyebrow">Adams Farm Labradoodles</p>
        <h2>Where Every Puppy Grows Up Loved</h2>
        <p class="s-about-body">Adams Farm Labradoodles breeds and raises ALAA registered Australian Labradoodles. Our breeding dogs are raised in loving homes, health tested, and evaluated for therapy-dog temperament. Our puppies are raised to be calm and confident in new environments.</p>
        <a href="/our-program" class="trust-program-link">Learn more about our program &rarr;</a>
        <div class="trust-grid">
          <div class="trust-card">
            <svg class="trust-icon" width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
              <path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/>
            </svg>
            <h3 class="trust-card-heading">ALAA Gold Paw Accredited</h3>
            <p class="trust-card-body">Our highest health-testing standard under the Australian Labradoodle Association of America.</p>
          </div>
          <div class="trust-card">
            <svg class="trust-icon" width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
              <polygon points="13 2 3 14 12 14 11 22 21 10 12 10 13 2"/>
            </svg>
            <h3 class="trust-card-heading">Early Neurological Stimulation</h3>
            <p class="trust-card-body">Starting at day 3, the same neurological exercises developed for military working dogs.</p>
          </div>
          <div class="trust-card">
            <svg class="trust-icon" width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
              <path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/>
              <polyline points="9 12 11 14 15 10"/>
            </svg>
            <h3 class="trust-card-heading">3-Year Health Guarantee</h3>
            <p class="trust-card-body">We test for known congenital defects and guarantee what can&rsquo;t be tested for, for three years.</p>
          </div>
          <div class="trust-card">
            <svg class="trust-icon" width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
              <path d="M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 0 0-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 0 0 0-7.78z"/>
            </svg>
            <h3 class="trust-card-heading">Puppy Therapy&trade; Certified</h3>
            <p class="trust-card-body">Every puppy meets and exceeds the Rule of Sevens socialization standard during the critical 3&ndash;12 week window.</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ④ TESTIMONIALS: featured + 2-col grid -->
  <section class="s-testimonials section">
    <div class="container s-section-header">
      <p class="eyebrow">Testimonials</p>
      <h2>Loved by Families</h2>
    </div>
    <div class="container s-testimonials-grid">
      <div class="t-card t-card-featured">
        <blockquote class="t-quote">&ldquo;We are smitten with our bright &amp; adorable Australian Labradoodle from Adam&rsquo;s Farm Labradoodles. Paisley is such a happy girl. She draws attention from people everywhere she goes. She adjusted seamlessly to our home, our routines, and older dog. From the beginning she showed good manners, confidence, and a loving temperament.&rdquo;</blockquote>
        <p class="t-attr">&mdash; Deirdre</p>
      </div>
      <div class="t-card">
        <blockquote class="t-quote">&ldquo;An amazing family operated company. We love our dog, Samson, more than words can describe. He is calm and loving &mdash; we can tell he was born into an environment of care. Doug &amp; Erika are awesome and provided us with all the information we needed as soon as we bought Samson.&rdquo;</blockquote>
        <p class="t-attr">&mdash; Imani-Grace</p>
      </div>
      <div class="t-card">
        <blockquote class="t-quote">&ldquo;We had just moved to the U.S. from Japan, and never expected to meet such a kind and wonderful breeder family so soon. It truly felt like fate. Thanks to Adams Farm, not only did we meet amazing people, but we also welcomed a new, loving member into our family.&rdquo;</blockquote>
        <p class="t-attr">&mdash; Serina</p>
      </div>
    </div>
    <div class="container s-testimonials-cta">
      <a href="https://share.google/FmRRIkSGouEi3RIFT" target="_blank" rel="noopener noreferrer" class="trust-program-link">Read more reviews on Google &rarr;</a>
    </div>
  </section>

  <!-- ⑤ WHY AUSTRALIAN LABRADOODLE -->
  <section class="s-why section">
    <div class="container s-why-inner">
      <div class="s-why-text">
        <p class="eyebrow">Authentic Australian Labradoodle</p>
        <h2>Better Breed By Design</h2>
        <p class="s-why-body">Adams Farm is an ALAA-registered breeding program, held to a real standard for lineage, health testing, and temperament. Every puppy we place is guaranteed 100% non-shedding and allergy friendly &mdash; the result of that standard, not a coincidence.</p>
      </div>
      <img src="/images/credentials/Better-Breed-By-Design-Badge.png" alt="Better Breed by Design" class="s-why-badge" />
    </div>
    <div class="container s-why-cards">
      <div class="trust-card">
        <h3 class="trust-card-heading">ALAA Registered &mdash; Verified Pedigree</h3>
        <p class="trust-card-body">Every pedigree is verified against ALAA&rsquo;s official database &mdash; the only reliable way to confirm true lineage.</p>
      </div>
      <div class="trust-card">
        <h3 class="trust-card-heading">Multi-Generational</h3>
        <p class="trust-card-body">A true Australian Labradoodle has two Australian Labradoodle parents &mdash; a distinct breed, not a mixed litter.</p>
      </div>
      <div class="trust-card">
        <h3 class="trust-card-heading">Non-Shedding, Allergy-Friendly Coat</h3>
        <p class="trust-card-body">A carefully bred, low-to-no-shedding coat makes the breed allergy friendly.</p>
      </div>
      <div class="trust-card">
        <h3 class="trust-card-heading">Temperament Tested</h3>
        <p class="trust-card-body">Bred for a clever, joyful temperament that reads people &mdash; ideal for therapy and family life.</p>
      </div>
    </div>
    <div class="container s-why-cta">
      <a href="https://alaa-labradoodles.com/for-breeders/breed-standard/" target="_blank" rel="noopener noreferrer" class="trust-program-link">Learn more from ALAA &rarr;</a>
    </div>
  </section>

  <!-- ⑥ BREAK SECTION: centered full-width quote -->
  <section class="s-break">
    <div class="container s-break-inner">
      <blockquote class="break-quote">
        &ldquo;Dogs are not our whole life,<br class="break-quote-br" /> but they make our lives whole.&rdquo;
        <cite class="break-cite">&mdash; Roger Caras</cite>
      </blockquote>
    </div>
  </section>

  <!-- ⑦ OUR STORY: two-column — text left, image right -->
  <section class="s-story section" id="story">
    <div class="container s-story-inner">
      <div class="s-story-text">
        <p class="eyebrow">Our Story</p>
        <h2>How Adams Farm Began</h2>
        <p class="s-story-body">It started with our kids, Julian and Marie Claire, begging for a puppy. Instead of one, we decided to give them puppies &mdash; and set out to find the right breed. Our only real requirement was temperament: friendly, with no aggression toward people, dogs, or other animals. That search led us to Australian Labradoodles, and eventually to Mike and Pam Kirkpatrick of Legend Manor Labradoodles, and their dog Prancer &mdash; Winnie.</p>
        <p class="s-story-body">From the moment we met her, Erika knew. Winnie approached each of us gently, and it was clear how loving she was &mdash; the kind of dog that becomes a healing presence for a family. She joined ours, and after her third litter, gave us eight healthy puppies. That&rsquo;s how Adams Farm began.</p>
        <blockquote class="s-story-pullquote">
          &ldquo;A great dog can be a healing presence for your whole family.&rdquo;
          <cite class="s-story-cite">&mdash; Erika Campbell</cite>
        </blockquote>
      </div>
      <div class="story-photo">
        <img
          src="/images/story/founder-story-portrait.jpg"
          alt="Douglas and Erika Campbell with Winnie"
          class="story-photo-img"
        />
      </div>
    </div>
  </section>

  <!-- ⑧ CREDENTIALS & PARTNERS: scrollable badge carousel -->
  <section class="s-creds">
    <div class="container">
      <div class="creds-track-wrap">
        <button class="carousel-btn carousel-btn-prev" id="creds-prev" aria-label="Scroll left">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M15 18l-6-6 6-6"/></svg>
        </button>
        <div class="s-scroll" id="creds-scroll">
          <img src="/images/credentials/akc-reunite-badge.png" alt="AKC Reunite" class="creds-logo" />
          <img src="/images/credentials/baxter-bella.png" alt="Baxter &amp; Bella" class="creds-logo" />
          <img src="/images/credentials/Adams-Farm-Gold-Paw-Badge-2026.png" alt="ALAA Gold Paw Breeder 2026–2027" class="creds-logo" />
          <img src="/images/credentials/trupanion-badge.png" alt="Trupanion" class="creds-logo" />
          <img src="/images/credentials/badass-breeder.png" alt="Badass Breeder" class="creds-logo" />
          <img src="/images/credentials/revival-animal-health-badge.png" alt="Revival Animal Health" class="creds-logo" />
        </div>
        <button class="carousel-btn carousel-btn-next" id="creds-next" aria-label="Scroll right">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M9 18l6-6-6-6"/></svg>
        </button>
      </div>
    </div>
  </section>

  <script>
    const credsTrack = document.getElementById('creds-scroll') as HTMLElement | null;
    const credsPrev  = document.getElementById('creds-prev')   as HTMLButtonElement | null;
    const credsNext  = document.getElementById('creds-next')   as HTMLButtonElement | null;

    function updateCredsArrows() {
      if (!credsTrack || !credsPrev || !credsNext) return;
      credsPrev.style.display = credsTrack.scrollLeft <= 1 ? 'none' : 'flex';
      credsNext.style.display = credsTrack.scrollLeft + credsTrack.clientWidth >= credsTrack.scrollWidth - 1 ? 'none' : 'flex';
    }
    function credsStep() {
      const logo = credsTrack?.querySelector('.creds-logo') as HTMLElement | null;
      return logo ? logo.offsetWidth + 20 : 220;
    }
    credsPrev?.addEventListener('click', () => { credsTrack?.scrollBy({ left: -credsStep(), behavior: 'smooth' }); });
    credsNext?.addEventListener('click', () => { credsTrack?.scrollBy({ left:  credsStep(), behavior: 'smooth' }); });
    credsTrack?.addEventListener('scroll', updateCredsArrows, { passive: true });
    requestAnimationFrame(updateCredsArrows);
  </script>

  <!-- ⑩ FAQ -->
  <section class="s-faq section">
    <div class="container s-section-header">
      <p class="eyebrow">FAQ</p>
      <h2>Frequently Asked Questions</h2>
    </div>
    <div class="container s-faq-list">

      <details class="faq-item">
        <summary class="faq-question">What is ALAA Gold Paw accreditation, and why does it matter?</summary>
        <div class="faq-answer"><p>Gold Paw is our highest health-testing standard under the Australian Labradoodle Association of America &mdash; the accrediting body that verifies pedigrees and sets the breed standard. It means every breeding dog in our program is health tested and verified, not just labeled &ldquo;Australian Labradoodle.&rdquo;</p></div>
      </details>

      <details class="faq-item">
        <summary class="faq-question">What makes an Australian Labradoodle different from other &ldquo;doodle&rdquo; breeds?</summary>
        <div class="faq-answer"><p>A true Australian Labradoodle is a multi-generational breed with both parents being Australian Labradoodles themselves &mdash; not a first-generation Lab and Poodle mix. Only dogs registered with ALAA, ALCA, or WALA are held to that standard.</p></div>
      </details>

      <details class="faq-item">
        <summary class="faq-question">Are Adams Farm puppies allergy friendly?</summary>
        <div class="faq-answer"><p>Yes. Every puppy we place is guaranteed 100% non-shedding and allergy friendly. As ALAA notes, no dog is truly hypoallergenic, but a carefully bred, low-to-no-shedding coat makes the breed a strong option for allergy-sensitive families.</p></div>
      </details>

      <details class="faq-item">
        <summary class="faq-question">What does &ldquo;raised in loving homes&rdquo; mean &mdash; do all your dogs live with you?</summary>
        <div class="faq-answer"><p>Puppies are whelped in the Campbell home. Some of our breeding dogs live with us, and others live with trusted guardian families &mdash; but every dog in our program is raised in a loving home, never a kennel.</p></div>
      </details>

      <details class="faq-item">
        <summary class="faq-question">What health guarantee comes with my puppy?</summary>
        <div class="faq-answer"><p>We test breeding dogs for known congenital defects and back what can&rsquo;t be tested for with a 3-year written guarantee, so your family can adopt with real confidence.</p></div>
      </details>

    </div>
  </section>

  <!-- ⑪ FOREVER FAMILIES: 7-photo mosaic grid -->
  <section class="s-families">
    <div class="container s-section-header s-section-header-light">
      <p class="eyebrow" style="color: rgba(247,242,231,0.65);">Forever Families</p>
      <h2 style="color: var(--color-cream);">Join the Adams Farm Forever Family</h2>
    </div>
    <div class="s-families-grid">
      <img src="/images/families/355x328.png"  alt="Adams Farm forever family with their puppy" class="families-photo" loading="lazy" />
      <img src="/images/families/Slot-2a.png"  alt="Adams Farm forever family with their puppy" class="families-photo" loading="lazy" />
      <img src="/images/families/Slot-3.jpg"   alt="Adams Farm forever family with their puppy" class="families-photo" loading="lazy" />
      <img src="/images/families/Slot-4.png"   alt="Adams Farm forever family with their puppy" class="families-photo" loading="lazy" />
      <img src="/images/families/Slot-2b.png"  alt="Adams Farm forever family with their puppy" class="families-photo" loading="lazy" />
    </div>
  </section>

  <!-- ⑫ APPLY NOW: CTA band with heading and button -->
  <section class="s-apply">
    <div class="container s-apply-inner">
      <p class="eyebrow s-apply-eyebrow">Get Started</p>
      <h2 class="s-apply-heading">Reserve Your Adams Farm Puppy</h2>
      <p class="s-apply-body">Our litters are small and spots fill quickly. Fill out a short application and we'll reach out to discuss your perfect match.</p>
      <a href="/contact" class="btn s-apply-btn">Apply Now</a>
    </div>
  </section>

  <!-- ⑬ FOOTER: Footer.astro (3-column, rendered by Layout) -->

</Layout>

<style>
  /* ─── HERO (unchanged) ──────────────────────────────────────── */
  .hero-section {
    position: relative;
    padding: 72px 0 88px;
  }
  .hero-bg {
    position: absolute;
    inset: 0;
    overflow: hidden;
    pointer-events: none;
    z-index: 0;
  }
  .bg-blob {
    position: absolute;
    border-radius: 50%;
  }
  .bb-mustard-tr {
    width: 560px;
    height: 560px;
    background: var(--color-mustard);
    opacity: 0.06;
    top: -60px;
    right: -60px;
  }
  .bb-pine-bl {
    width: 380px;
    height: 380px;
    background: var(--color-pine);
    opacity: 0.06;
    bottom: 20px;
    left: 20px;
  }
  .hero-grid {
    position: relative;
    z-index: 1;
    display: grid;
    grid-template-columns: 1.1fr 0.9fr;
    gap: 56px;
    align-items: center;
  }
  h1 {
    font-size: clamp(2rem, 4vw, 2.8rem);
    line-height: 1.15;
    margin-bottom: 20px;
  }
  .hero-copy {
    color: var(--color-muted);
    font-size: 1.05rem;
    max-width: 440px;
    margin: 0 0 28px;
    line-height: 1.7;
  }
  .hero-actions { display: flex; gap: 12px; flex-wrap: wrap; }
  .hero-photo-frame { position: relative; padding-bottom: 32px; }
  .hero-photo-masked {
    position: relative;
    z-index: 1;
    width: 100%;
    aspect-ratio: 1 / 1;
    clip-path: url(#hero-blob);
    overflow: hidden;
  }
  .hero-photo-img {
    width: 100%; height: 100%;
    object-fit: cover;
    object-position: center 15%;
    display: block;
  }
  .hero-testimonial {
    position: absolute;
    bottom: 0; left: 20px;
    max-width: 320px;
    background: var(--color-white);
    border-radius: 10px;
    padding: 14px 18px;
    box-shadow: 0 6px 28px rgba(0,0,0,0.12);
    z-index: 2;
  }
  .ht-quote {
    font-family: var(--font-display);
    font-style: italic;
    font-size: 0.88rem;
    color: var(--color-pine);
    margin: 0 0 6px;
    line-height: 1.45;
  }
  .ht-attr { font-size: 0.72rem; color: var(--color-muted); margin: 0; }

  /* ─── PLACEHOLDER BASE ──────────────────────────────────────── */
  .ph {
    background: #EDE8DF;
    border: 1.5px dashed #B8A98A;
    border-radius: 6px;
    color: #7A6B52;
    font-size: 0.72rem;
    font-family: var(--font-body);
    font-weight: 700;
    letter-spacing: 0.05em;
    display: flex;
    align-items: center;
    justify-content: center;
    text-align: center;
    padding: 12px 16px;
    line-height: 1.5;
  }

  /* ─── SHARED UTILITIES ──────────────────────────────────────── */
  .section { padding: 72px 0; }
  .s-section-header { margin-bottom: 32px; }
  .ph-label  { min-height: 44px; }
  .ph-tall   { min-height: 360px; }
  .ph-block  { min-height: 180px; }
  .ph-pullquote { min-height: 90px; }

  /* ─── ① PUPPIES ─────────────────────────────────────────────── */
