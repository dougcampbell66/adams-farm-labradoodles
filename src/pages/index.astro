---
import Layout from '../layouts/Layout.astro';
import { getCollection } from 'astro:content';

const allPuppies = await getCollection('puppies');
const springPuppies = allPuppies
  .filter(p => p.data.litter === 'spring-2026' && p.data.status === 'available')
  .sort((a, b) => (a.data.order ?? 99) - (b.data.order ?? 99));
---
<Layout title="Home">

  <!-- ─── HERO (unchanged) ─────────────────────────────────────── -->
  <svg width="0" height="0" style="position:absolute;pointer-events:none" aria-hidden="true">
    <defs>
      <clipPath id="hero-blob" clipPathUnits="objectBoundingBox">
        <path d="M 0.53,0.02 C 0.79,0.00 0.99,0.22 0.97,0.52 C 0.96,0.79 0.77,0.98 0.50,0.97 C 0.23,0.96 0.02,0.77 0.03,0.50 C 0.04,0.23 0.25,0.03 0.53,0.02 Z"/>
      </clipPath>
    </defs>
  </svg>

  <section class="hero-section">
    <div class="container hero-grid">
      <div class="hero-text">
        <p class="eyebrow">Australian Labradoodles</p>
        <h1>Raised in Loving Homes. Ready for Yours.</h1>
        <p class="hero-copy">Every litter comes from fully health-tested parents and grows up surrounded by family, before going to yours.</p>
        <div class="hero-actions">
          <a href="#puppies" class="btn btn-primary">See available puppies</a>
        </div>
      </div>
      <div class="hero-photo-frame">
        <div class="hero-photo-masked">
          <img
            src="/images/hero/founder-hero-portrait.jpg"
            alt="A girl holding an Adams Farm Labradoodle puppy"
            class="hero-photo-img"
          />
        </div>
      </div>
    </div>
  </section>

  <!-- ─── STATS BAR: quick credibility strip ──────────────────── -->
  <section class="s-stats">
    <div class="container s-stats-inner">
      <div class="stat">
        <span class="stat-number">6</span>
        <span class="stat-label">Litters</span>
      </div>
      <div class="stat">
        <span class="stat-number">56</span>
        <span class="stat-label">Puppies Raised</span>
      </div>
      <div class="stat">
        <span class="stat-number">15</span>
        <span class="stat-label">Five-Star Reviews</span>
      </div>
    </div>
  </section>

  <!-- ① PUPPIES: available puppies grid -->
  <section class="s-puppies" id="puppies">
    <div class="container s-puppies-hd">
      <p class="eyebrow">Available Puppies</p>
      <h2 class="puppies-heading">Meet Our Lilo &amp; Stitch May Litter</h2>
      <p class="puppies-sub">These practically perfect puppies come from Legend Manor&rsquo;s Holly and Tarheel&rsquo;s Knox, and are expected to mature into large minis between 20 and 25 lbs.</p>
      <p class="puppies-partner">Bred in partnership with Legend Manor Labradoodles</p>
      <a href="/our-dogs" class="puppies-parents-link">Meet the Parents &rarr;</a>
    </div>
    <div class="container puppies-grid">
      {springPuppies.map((p) => (
        <div class="puppy-card" data-status={p.data.status}>
          <div class="puppy-card-photo">
            <img src={p.data.photo} alt={p.data.name} loading="lazy" />
          </div>
          <div class="puppy-card-body">
            <span class="puppy-name">{p.data.name}</span>
            {p.data.collar && <span class="puppy-collar">{p.data.collar}</span>}
            <div class="puppy-badges">
              {p.data.sex && <span class="puppy-sex">{p.data.sex}</span>}
              <span class={`litter-status litter-status-${p.data.status}`}>
                {p.data.status.charAt(0).toUpperCase() + p.data.status.slice(1)}
              </span>
            </div>
          </div>
        </div>
      ))}
    </div>
    <div class="container puppies-cta">
      <a href="/contact" class="btn btn-primary">Reserve a Puppy</a>
    </div>
  </section>

  <!-- NEW ─── PROGRAM: 4-card phase framework ────────────────── -->
  <section class="s-program section">
    <div class="container s-section-header">
      <p class="eyebrow">Our Program</p>
      <h2>PuppyQ Raised and Certified</h2>
      <p class="s-program-intro">PuppyQ is an evidence-based framework for raising calm puppies.<br />Q stands for Quotient, marking four developmental periods from birth to adulthood. Adams Farm raises each puppy with intention and tracks benchmarks in the PuppyQ framework. Every puppy goes home with its PuppyQ Certification, Scorecard, and History.</p>
    </div>
    <div class="container s-program-grid">
      <div class="prog-card prog-card-green" tabindex="0">
        <div class="prog-card-inner">
          <div class="prog-face prog-face-front">
            <p class="prog-phase"><span class="prog-badge">1</span>Neonatal Period</p>
            <p class="prog-timeframe">Day 0–14</p>
            <p class="prog-front-body">Puppies are born blind and deaf, their brains not yet ready to learn.</p>
          </div>
          <div class="prog-face prog-face-back">
            <p class="prog-back-body">Every puppy is weighed and gently handled, one on one, every single day.</p>
          </div>
        </div>
      </div>
      <div class="prog-card prog-card-blue" tabindex="0">
        <div class="prog-card-inner">
          <div class="prog-face prog-face-front">
            <p class="prog-phase"><span class="prog-badge">2</span>Transition Period</p>
            <p class="prog-timeframe">Day 14–21</p>
            <p class="prog-front-body">Eyes and ears open and the puppy comes online for the first time.</p>
          </div>
          <div class="prog-face prog-face-back">
            <p class="prog-back-body">Handling stays calm and quiet while first impressions form.</p>
          </div>
        </div>
      </div>
      <div class="prog-card prog-card-yellow" tabindex="0">
        <div class="prog-card-inner">
          <div class="prog-face prog-face-front">
            <p class="prog-phase"><span class="prog-badge">3</span>Socialization Period</p>
            <p class="prog-timeframe">Week 3–12</p>
            <p class="prog-front-body">The critical window for meeting the world &mdash; and it stays open after your puppy comes home.</p>
          </div>
          <div class="prog-face prog-face-back">
            <p class="prog-back-body">Puppies meet people, places, and friendly dogs through steady, everyday exposure.</p>
          </div>
        </div>
      </div>
      <div class="prog-card prog-card-red" tabindex="0">
        <div class="prog-card-inner">
          <div class="prog-face prog-face-front">
            <p class="prog-phase"><span class="prog-badge">4</span>Juvenile Period</p>
            <p class="prog-timeframe">Week 12 to sexual maturity</p>
            <p class="prog-front-body">The socialization window has closed and your growing puppy enters adolescence.</p>
          </div>
          <div class="prog-face prog-face-back">
            <p class="prog-back-body">Keep up the outings and routines that carry the foundation forward.</p>
          </div>
        </div>
      </div>
    </div>
    <div class="container s-program-timeline">
      <svg viewBox="0 0 1000 220" xmlns="http://www.w3.org/2000/svg" style="width:100%; max-width:900px; height:auto; display:block; margin:2rem auto 0;">
        <line x1="125" y1="110" x2="875" y2="110" stroke="var(--color-border-dark)" stroke-width="3"/>
        <circle cx="125" cy="110" r="34" fill="var(--color-focus-green)"/>
        <circle cx="375" cy="110" r="34" fill="var(--color-calm-blue)"/>
        <circle cx="625" cy="110" r="34" fill="var(--color-excite-yellow)"/>
        <circle cx="875" cy="110" r="34" fill="var(--color-feelings-red)"/>
        <text x="125" y="117" text-anchor="middle" fill="#fff" font-size="22" font-weight="700">1</text>
        <text x="375" y="117" text-anchor="middle" fill="#fff" font-size="22" font-weight="700">2</text>
        <text x="625" y="117" text-anchor="middle" fill="#fff" font-size="22" font-weight="700">3</text>
        <text x="875" y="117" text-anchor="middle" fill="#fff" font-size="22" font-weight="700">4</text>
        <text x="125" y="170" text-anchor="middle" fill="var(--color-card)" font-size="15" font-weight="600">Day 0–14</text>
        <text x="375" y="170" text-anchor="middle" fill="var(--color-card)" font-size="15" font-weight="600">Day 14–21</text>
        <text x="625" y="170" text-anchor="middle" fill="var(--color-card)" font-size="15" font-weight="600">Week 3–12</text>
        <text x="875" y="170" text-anchor="middle" fill="var(--color-card)" font-size="15" font-weight="600">Week 12–maturity</text>
      </svg>
    </div>
  </section>

  <script>
    document.querySelectorAll('.prog-card').forEach(card => {
      card.addEventListener('click', () => {
        if (window.matchMedia('(hover: none)').matches) {
          card.classList.toggle('is-flipped');
        }
      });
    });
  </script>

  <!-- ② ABOUT ADAMS FARM + ③ TRUST: image left, text + 2×2 trust grid right -->
  <section class="s-about section">
    <div class="container s-about-inner">
      <div class="about-photo">
        <img
          src="/images/story/douglas-erika-winnie.jpg"
          alt="Douglas and Erika Campbell with Winnie"
          class="about-photo-img"
        />
      </div>
      <div class="s-about-text">
        <p class="eyebrow">ALAA Gold Paw Accredited</p>
        <h2>Adams Farm Labradoodles</h2>
        <p class="s-about-body">We are the Campbell Family. We have been raising Australian Labradoodles since January 2022. It began with the adoption of Legend Manor&rsquo;s Prancer who became our foundation dog. We are committed to breeding and raising puppies and dogs with love and intention. We strive to improve our program and do something really meaningful in the lives of people and dogs.</p>
        <div class="s-about-pillars">
          <div class="about-pillar">
            <h3 class="about-pillar-heading">Health, Verified</h3>
            <p class="about-pillar-body">ALAA Gold Paw accredited, with full hip, elbow, eye, and genetic testing on every breeding pair.</p>
          </div>
          <div class="about-pillar">
            <h3 class="about-pillar-heading">Raised on PuppyQ</h3>
            <p class="about-pillar-body">Every puppy is individually handled from birth, then introduced to the world starting at four weeks old.</p>
          </div>
          <div class="about-pillar">
            <h3 class="about-pillar-heading">Built for Families</h3>
            <p class="about-pillar-body">Non-shedding, allergy-friendly coats, and a 3-year health guarantee behind every puppy we place.</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ④ TESTIMONIALS: featured + 2-col grid -->
  <section class="s-testimonials section" id="testimonials">
    <div class="container s-section-header">
      <p class="eyebrow">Testimonials</p>
      <h2>Loved by Families</h2>
    </div>
    <div class="container s-testimonials-widget">
      <div class="elfsight-app-460e5003-87bc-4cbe-a8d7-8d93a30a0ad2" data-elfsight-app-lazy></div>
    </div>
  </section>

  <!-- ⑤ WHY AUSTRALIAN LABRADOODLE -->
  <section class="s-why section">
    <div class="container s-why-inner">
      <div class="s-why-text">
        <p class="eyebrow">Better Breed by Design</p>
        <h2>Australian Labradoodle<br />Association of America</h2>
        <p class="s-why-body">The Australian Labradoodle Association of America (ALAA) has been protecting and improving the Australian Labradoodle breed since 2004. ALAA sets the health-testing and breeding standards every member breeder must meet, verifies pedigrees, and holds breeders accountable to a formal code of ethics &mdash; reviewed and renewed annually.</p>
      </div>
      <img src="/images/credentials/better-breed-by-design-badge.png" alt="Better Breed by Design" class="s-why-badge" />
    </div>
    <div class="container s-why-cards">
      <div class="trust-card">
        <h3 class="trust-card-heading">Verified Pedigree</h3>
        <p class="trust-card-body">ALAA Australian Labradoodles have a verified pedigree that is checked against ALAA&rsquo;s official database to confirm lineage.</p>
      </div>
      <div class="trust-card">
        <h3 class="trust-card-heading">Multi-Generational</h3>
        <p class="trust-card-body">ALAA Australian Labradoodles have two registered parents and a lineage going back multiple generations.</p>
      </div>
      <div class="trust-card">
        <h3 class="trust-card-heading">Allergy-Friendly Coat</h3>
        <p class="trust-card-body">ALAA Australian Labradoodles have a low shedding, curly or wavy coat that makes them allergy friendly for most people.</p>
      </div>
      <div class="trust-card">
        <h3 class="trust-card-heading">Temperament Bred</h3>
        <p class="trust-card-body">ALAA Australian Labradoodles are bred for wonderful temperaments, making them ideal for families and therapy work.</p>
      </div>
    </div>
    <div class="container s-why-cta">
      <a href="https://alaa-labradoodles.com/for-breeders/breed-standard/" target="_blank" rel="noopener noreferrer" class="trust-program-link">Learn more from ALAA &rarr;</a>
    </div>
  </section>

  <!-- ⑥ BREAK SECTION: centered full-width quote -->
  <section class="s-break">
    <div class="container s-break-inner">
      <blockquote class="break-quote">
        &ldquo;Dogs are not our whole life,<br class="break-quote-br" /> but they make our lives whole.&rdquo;
        <cite class="break-cite">&mdash; Roger Caras</cite>
      </blockquote>
    </div>
  </section>


  <!-- ⑧ CREDENTIALS & PARTNERS: static grid -->
  <section class="s-creds">
    <div class="container s-section-header">
      <p class="eyebrow">Trusted Partners</p>
      <h2>Our Partners</h2>
      <p class="creds-desc">Every Adams Farm puppy is raised with help from our incredible partners.</p>
    </div>
    <div class="container creds-grid">
      <div class="creds-card">
        <img src="/images/credentials/sq-gold-paw.png" alt="ALAA Gold Paw Breeder 2026–2027" class="creds-logo" />
      </div>
      <div class="creds-card">
        <img src="/images/credentials/sq-akc-reunite.png" alt="AKC Reunite" class="creds-logo" />
      </div>
      <div class="creds-card">
        <img src="/images/credentials/sq-trupanion.png" alt="Trupanion" class="creds-logo" />
      </div>
      <div class="creds-card">
        <img src="/images/credentials/sq-purina.png" alt="Purina Pro Club" class="creds-logo" />
      </div>
      <div class="creds-card">
        <img src="/images/credentials/sq-puppyq.png" alt="PuppyQ" class="creds-logo" />
      </div>
      <div class="creds-card">
        <img src="/images/credentials/baxter-and-bella-logo.png" alt="Baxter &amp; Bella" class="creds-logo" />
      </div>
      <div class="creds-card creds-card-placeholder"></div>
      <div class="creds-card creds-card-placeholder"></div>
    </div>
  </section>

  <!-- ⑩ JOIN US: two ways to get involved -->
  <section class="s-join">
    <div class="container s-section-header s-section-header-light">
      <p class="eyebrow s-join-eyebrow">Get Involved</p>
      <h2 class="s-join-heading">Join Us</h2>
      <p class="s-join-intro">We breed to do something really meaningful in the lives of people, puppies, and dogs. In our brief time as a breeder, we&rsquo;ve touched over 15,000 total lives. Would you like to help us in our mission?</p>
    </div>
    <div class="container s-join-grid">
      <div class="join-col">
        <span class="join-badge">1</span>
        <h3 class="join-heading">Become a Guardian</h3>
        <p class="join-body">Provide a loving home for one of our breeding dogs, while we handle the rest.</p>
        <a href="/guardians" class="join-link">Learn About Guardians &rarr;</a>
      </div>
      <div class="join-col">
        <span class="join-badge">2</span>
        <h3 class="join-heading">Become an Ambassador</h3>
        <p class="join-body">Help us socialize our puppies and spread a little puppy joy.</p>
        <a href="/ambassadors" class="join-link">Learn About Ambassadors &rarr;</a>
      </div>
    </div>
  </section>

  <!-- ⑪ FAQ -->
  <section class="s-faq section" id="faq">
    <div class="container s-section-header">
      <p class="eyebrow">FAQ</p>
      <h2>Frequently Asked Questions</h2>
    </div>
    <div class="container s-faq-list">

      <details class="faq-item">
        <summary class="faq-question">What is ALAA Gold Paw accreditation, and why does it matter?</summary>
        <div class="faq-answer"><p>Gold Paw is our highest health-testing standard under the Australian Labradoodle Association of America &mdash; the accrediting body that verifies pedigrees and sets the breed standard. It means every breeding dog in our program is health tested and verified, not just labeled &ldquo;Australian Labradoodle.&rdquo;</p></div>
      </details>

      <details class="faq-item">
        <summary class="faq-question">What makes an Australian Labradoodle different from other &ldquo;doodle&rdquo; breeds?</summary>
        <div class="faq-answer"><p>A true Australian Labradoodle is a multi-generational breed with both parents being Australian Labradoodles themselves &mdash; not a first-generation Lab and Poodle mix. Only dogs registered with ALAA, ALCA, or WALA are held to that standard.</p></div>
      </details>

      <details class="faq-item">
        <summary class="faq-question">Are Adams Farm puppies allergy friendly?</summary>
        <div class="faq-answer"><p>Yes. Every puppy we place is guaranteed 100% non-shedding and allergy friendly. As ALAA notes, no dog is truly hypoallergenic, but a carefully bred, low-to-no-shedding coat makes the breed a strong option for allergy-sensitive families.</p></div>
      </details>

      <details class="faq-item">
        <summary class="faq-question">What does &ldquo;raised in loving homes&rdquo; mean &mdash; do all your dogs live with you?</summary>
        <div class="faq-answer"><p>Puppies are whelped in the Campbell home. Some of our breeding dogs live with us, and others live with trusted guardian families &mdash; but every dog in our program is raised in a loving home, never a kennel.</p></div>
      </details>

      <details class="faq-item">
        <summary class="faq-question">What health guarantee comes with my puppy?</summary>
        <div class="faq-answer"><p>We test breeding dogs for known congenital defects and back what can&rsquo;t be tested for with a 3-year written guarantee, so your family can adopt with real confidence.</p></div>
      </details>

    </div>
  </section>

  <!-- ⑫ APPLY NOW: CTA band with heading and button -->
  <section class="s-apply">
    <div class="container s-apply-inner">
      <p class="eyebrow s-apply-eyebrow">Get Started</p>
      <h2 class="s-apply-heading">Reserve Your Adams Farm Puppy</h2>
      <p class="s-apply-body">Our litters are small and spots fill quickly. Fill out a short application and we'll reach out to discuss your perfect match.</p>
      <a href="/contact" class="btn s-apply-btn">Apply Now</a>
    </div>
  </section>

  <!-- ⑬ FOOTER: Footer.astro (3-column, rendered by Layout) -->

</Layout>

<style>
  /* ─── HERO ──────────────────────────────────────────────────── */
  .hero-section {
    position: relative;
    padding: 72px 0 88px;
    background: var(--color-pine);
  }
  .hero-section .eyebrow { color: rgba(220,229,219,0.7); }
  .hero-section h1 { color: var(--color-card); }
  .hero-section .hero-copy { color: rgba(237,227,208,0.75); }
  .hero-section .btn-primary {
    background: var(--color-brass);
    color: var(--color-charcoal);
    border-color: transparent;
  }
  .hero-section .btn-primary:hover {
    filter: brightness(0.9);
  }
  .hero-grid {
    display: grid;
    grid-template-columns: 0.96fr 1.04fr;
    gap: 56px;
    align-items: center;
  }
  h1 {
    font-size: clamp(2rem, 4vw, 2.8rem);
    line-height: 1.15;
    margin-bottom: 20px;
  }
  .hero-copy {
    color: var(--color-muted);
    font-size: 1.05rem;
    max-width: 440px;
    margin: 0 0 28px;
    line-height: 1.7;
  }
  .hero-actions { display: flex; gap: 12px; flex-wrap: wrap; }
  .hero-photo-frame { position: relative; }
  .hero-photo-masked {
    position: relative;
    z-index: 1;
    width: 100%;
    aspect-ratio: 1 / 1;
    clip-path: url(#hero-blob);
    overflow: hidden;
  }
  .hero-photo-img {
    width: 100%; height: 100%;
    object-fit: cover;
    object-position: center 15%;
    display: block;
  }

  /* ─── PLACEHOLDER BASE ──────────────────────────────────────── */
  .ph {
    background: #EDE8DF;
    border: 1.5px dashed #B8A98A;
    border-radius: 6px;
    color: #7A6B52;
    font-size: 0.72rem;
    font-family: var(--font-body);
    font-weight: 700;
    letter-spacing: 0.05em;
    display: flex;
    align-items: center;
    justify-content: center;
    text-align: center;
    padding: 12px 16px;
    line-height: 1.5;
  }

  /* ─── SHARED UTILITIES ──────────────────────────────────────── */
  .section { padding: 72px 0; }
  .s-section-header { margin-bottom: 32px; }
  .ph-label  { min-height: 44px; }
  .ph-tall   { min-height: 360px; }
  .ph-block  { min-height: 180px; }
  .ph-pullquote { min-height: 90px; }

  .s-puppies h2, .s-about h2, .s-why h2, .s-faq h2 { color: var(--color-pine); }

  /* ─── STATS BAR ─────────────────────────────────────────────── */
  .s-stats {
    background: var(--color-cream-d);
    padding: 28px 0 32px;
    border-top: 1px solid var(--color-border-light);
  }
  .s-stats-inner {
    display: flex;
    justify-content: center;
    gap: 64px;
    flex-wrap: wrap;
  }
  .stat {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 4px;
  }
  .stat-number {
    font-family: var(--font-display);
    font-size: clamp(2rem, 4vw, 2.6rem);
    font-weight: 700;
    line-height: 1;
    color: var(--color-pine);
  }
  .stat-label {
    font-size: 0.72rem;
    font-weight: 700;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--color-muted);
  }
  @media (max-width: 640px) {
    .s-stats-inner { flex-direction: column; gap: 20px; }
  }

  /* ─── ① PUPPIES ─────────────────────────────────────────────── */
  .s-puppies {
    padding: 64px 0;
    background: var(--color-white);
    border-top: 1px solid var(--color-border-light);
  }
  .s-puppies-hd { margin-bottom: 32px; }
  .puppies-heading { margin: 0 0 var(--space-heading-gap); }
  .puppies-sub {
    color: var(--color-muted);
    font-size: 0.95rem;
    line-height: 1.65;
    max-width: 560px;
    margin: 0 0 10px;
  }
  .puppies-partner {
    font-size: 0.85rem;
    font-style: italic;
    color: var(--color-muted);
    margin: 0 0 var(--space-cta-gap);
  }
  /* shared visual style for all section CTA text links */
  .puppies-parents-link,
  .trust-program-link {
    font-size: 0.85rem;
    font-weight: 700;
    color: var(--color-pine);
    text-decoration: none;
    border-bottom: 1.5px solid var(--color-brass);
    padding-bottom: 2px;
  }
  .puppies-cta {
    margin-top: 32px;
  }

  .puppies-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 20px;
  }

  .puppy-card {
    background: var(--color-charcoal-bg);
    border-radius: 12px;
    overflow: hidden;
  }
  .puppy-card-photo {
    width: 100%;
    aspect-ratio: 3 / 4;
