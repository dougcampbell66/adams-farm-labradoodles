---
import Layout from '../layouts/Layout.astro';
---
<Layout title="Contact" description="Get in touch with Adams Farm Labradoodles — questions about puppies, health testing, and the waitlist.">
  <div class="page-hero">
    <div class="container">
      <p class="eyebrow">Get in touch</p>
      <h1>Contact Adams Farm</h1>
      <p class="page-intro">Questions about an available puppy, the waitlist, or our program? Send us a message — we respond within 1–2 business days.</p>
    </div>
  </div>

  <section class="section">
    <div class="container contact-layout">

      <div class="contact-info">
        <h2 class="info-heading">What happens next</h2>
        <ol class="next-steps">
          <li>We read every message personally and respond within 1–2 business days.</li>
          <li>We'll ask a few questions about your home, lifestyle, and what you're looking for.</li>
          <li>If it's a great fit, we'll add you to our waitlist and keep you posted on upcoming litters.</li>
        </ol>

        <div class="contact-details">
          <div class="detail-block">
            <p class="detail-label">Location</p>
            <p class="detail-value">Greensboro, NC</p>
          </div>
          <div class="detail-block">
            <p class="detail-label">Visits</p>
            <p class="detail-value">By appointment — we welcome families to meet the dogs before committing.</p>
          </div>
        </div>
      </div>

      <div class="form-col">
        <form name="contact" method="POST" data-netlify="true" netlify-honeypot="bot-field" class="contact-form">
          <input type="hidden" name="form-name" value="contact" />
          <p class="hidden-field">
            <label>Don't fill this out: <input name="bot-field" /></label>
          </p>

          <label class="field-label">
            Name
            <input type="text" name="name" required placeholder="Your full name" />
          </label>

          <label class="field-label">
            Email
            <input type="email" name="email" required placeholder="you@example.com" />
          </label>

          <label class="field-label">
            Message
            <textarea name="message" rows="6" required placeholder="Tell us about yourself, your home, and what you're looking for in a dog."></textarea>
          </label>

          <button type="submit" class="btn btn-primary">Send message</button>
        </form>
      </div>

    </div>
  </section>
</Layout>

<style>
  .contact-layout {
    display: grid;
    grid-template-columns: 1fr 1.6fr;
    gap: 72px;
    align-items: start;
  }

  .info-heading {
    font-size: 0.72rem;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--color-muted);
    font-family: var(--font-body);
    font-weight: 700;
    margin-bottom: 16px;
  }
  .next-steps {
    padding-left: 18px;
    display: flex;
    flex-direction: column;
    gap: 12px;
    color: var(--color-charcoal);
    line-height: 1.65;
    font-size: 0.95rem;
    margin: 0;
  }
  .contact-details {
    margin-top: 36px;
    display: flex;
    flex-direction: column;
    gap: 18px;
  }
  .detail-block { margin: 0; }
  .detail-label {
    font-size: 0.72rem;
    font-weight: 700;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--color-muted);
    margin: 0 0 3px;
  }
  .detail-value {
    font-size: 0.92rem;
    color: var(--color-charcoal);
    margin: 0;
    line-height: 1.55;
  }

  .contact-form {
    display: flex;
    flex-direction: column;
    gap: 18px;
  }
  .field-label {
    display: flex;
    flex-direction: column;
    gap: 6px;
    font-size: 0.88rem;
    font-weight: 700;
    color: var(--color-pine);
    letter-spacing: 0.01em;
  }
  .contact-form input,
  .contact-form textarea {
    font-family: var(--font-body);
    font-size: 0.95rem;
    padding: 11px 14px;
    border: 1.5px solid var(--color-border-light);
    border-radius: 6px;
    background: var(--color-white);
    color: var(--color-charcoal);
    transition: border-color 0.15s;
  }
  .contact-form input:focus,
  .contact-form textarea:focus {
    outline: none;
    border-color: var(--color-pine);
  }
  .contact-form input::placeholder,
  .contact-form textarea::placeholder {
    color: #C0BAB2;
  }
  .contact-form button {
    align-self: flex-start;
    margin-top: 4px;
  }
  .hidden-field { display: none; }

  @media (max-width: 768px) {
    .contact-layout {
      grid-template-columns: 1fr;
      gap: 40px;
    }
  }
</style>
