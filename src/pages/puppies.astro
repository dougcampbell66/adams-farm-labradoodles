---
import Layout from '../layouts/Layout.astro';
import { getCollection } from 'astro:content';

const litters = await getCollection('litters');
const puppyEntries = await getCollection('puppies');

// Current litter — the active (available/reserved) litter, mirroring the homepage.
const activeLitter = litters
  .filter(l => l.data.status === 'available' || l.data.status === 'reserved')
  .sort((a, b) => new Date(b.data.birthdate).getTime() - new Date(a.data.birthdate).getTime())[0];

// Same filtering logic as the homepage's Available Puppies section: available only.
const currentPuppies = activeLitter
  ? puppyEntries
      .filter(p => p.data.litter === activeLitter.slug && p.data.status === 'available')
      .sort((a, b) => (a.data.order ?? 99) - (b.data.order ?? 99))
  : [];

function fmtDate(dateStr: string) {
  return new Date(dateStr + 'T12:00:00').toLocaleDateString('en-US', {
    month: 'long', day: 'numeric', year: 'numeric'
  });
}

// Past litters — confirmed ALAA track record, newest first. Puppies kept for the
// breeding program are shown as counts only, never named; no registration numbers.
const pastLitters = [
  { sire: 'Silas', dam: 'Winnie', date: 'February 24, 2026', puppies: ['Chelsea', 'Madison', 'Tori', 'Hudson', 'Toffi', 'Miklo'], retained: 0 },
  { sire: 'Silas', dam: 'Macy',   date: 'February 4, 2026',  puppies: ['Coral', 'Deb', 'Marlin', 'Dory', 'Nemo'], retained: 0 },
  { sire: 'Silas', dam: 'Winnie', date: 'August 3, 2025',    puppies: ['Zola', 'Mili', 'Callie', 'River', 'Baby Peanut', 'Hazel', 'Snow White'], retained: 1 },
  { sire: 'Silas', dam: 'Winnie', date: 'January 8, 2025',   puppies: ['Maui', 'James Dean', 'Samson King', 'Elizabeth Taylor', 'Butters', 'Douglas Carter'], retained: 2 },
  { sire: 'Chewy', dam: 'Winnie', date: 'July 8, 2024',      puppies: ['Hudson', 'Jaxon', 'Macy', 'Grace', 'Luca', 'Finn', 'Caeli', 'Izzy', 'Lia'], retained: 0 },
];
---
<Layout title="Puppies" description="Current, planned, and past Australian Labradoodle litters from Adams Farm Labradoodles in Greensboro, NC.">
  <div class="page-hero">
    <div class="container">
      <p class="eyebrow">Our Puppies</p>
      <h1>Puppies</h1>
      <p class="page-intro">Our current litter, what&rsquo;s ahead, and the track record behind them.</p>
    </div>
  </div>

  <!-- CURRENT LITTER -->
  <section class="section pup-section" id="current-litter">
    <div class="container">
      <div class="pup-head">
        <p class="eyebrow">Current Litter</p>
        <h2>{activeLitter ? activeLitter.data.title : 'Current Litter'}</h2>
        {activeLitter && (
          <p class="pup-sub">Sire: {activeLitter.data.sire} &middot; Dam: {activeLitter.data.dam} &middot; Born {fmtDate(activeLitter.data.birthdate)}</p>
        )}
        {activeLitter?.slug === 'spring-2026' && (
          <p class="pup-partner">Bred in partnership with Legend Manor Labradoodles</p>
        )}
      </div>

      {currentPuppies.length > 0 ? (
        <div class="puppies-grid">
          {currentPuppies.map(p => (
            <div class="puppy-card" data-status={p.data.status}>
              <div class="puppy-card-photo">
                <img src={p.data.photo} alt={p.data.name} loading="lazy" />
              </div>
              <div class="puppy-card-body">
                <span class="puppy-name">{p.data.name}</span>
                {p.data.collar && <span class="puppy-collar">{p.data.collar}</span>}
                <div class="puppy-badges">
                  {p.data.sex && <span class="puppy-sex">{p.data.sex}</span>}
                  <span class={`litter-status litter-status-${p.data.status}`}>
                    {p.data.status.charAt(0).toUpperCase() + p.data.status.slice(1)}
                  </span>
                </div>
              </div>
            </div>
          ))}
        </div>
      ) : (
        <p class="pup-empty">All puppies from our current litter are spoken for. <a href="/contact">Join our waitlist</a> for the next one.</p>
      )}

      <div class="pup-cta">
        <a href="/contact" class="btn btn-primary">Reserve a Puppy</a>
      </div>
    </div>
  </section>

  <!-- PLANNED LITTERS -->
  <section class="section pup-section pup-section-alt" id="planned">
    <div class="container">
      <div class="pup-head">
        <p class="eyebrow">Planned Litters</p>
        <h2>What&rsquo;s Ahead</h2>
      </div>
      <div class="pup-emptystate">
        <p>No litters currently planned. Check back soon, or <a href="/contact">contact us</a> to join our waitlist.</p>
      </div>
    </div>
  </section>

  <!-- PAST LITTERS -->
  <section class="section pup-section" id="past-litters">
    <div class="container">
      <div class="pup-head">
        <p class="eyebrow">Past Litters</p>
        <h2>Our Track Record</h2>
        <p class="pup-sub">A look back at every litter we&rsquo;ve raised, newest first.</p>
      </div>
      <div class="past-list">
        {pastLitters.map(litter => (
          <div class="past-litter">
            <div class="past-litter-head">
              <h3 class="past-litter-parents">{litter.sire} &times; {litter.dam}</h3>
              <span class="past-litter-date">{litter.date}</span>
            </div>
            <p class="past-litter-puppies">{litter.puppies.join(', ')}</p>
            {litter.retained > 0 && (
              <p class="past-litter-retained">&#43; {litter.retained} {litter.retained === 1 ? 'puppy' : 'puppies'} retained for breeding</p>
            )}
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- WAITLIST CTA -->
  <section class="waitlist-band">
    <div class="container waitlist-inner">
      <div>
        <p class="eyebrow waitlist-eyebrow">Future litters</p>
        <h2 class="waitlist-heading">Join the Waitlist</h2>
        <p class="waitlist-body">Our litters fill quickly. Getting on the list early means first access to puppy picks from upcoming litters.</p>
      </div>
      <a href="/contact" class="btn btn-secondary waitlist-btn">Get on the list</a>
    </div>
  </section>
</Layout>

<style>
  /* section rhythm */
  .pup-section { background: var(--color-white); }
  .pup-section-alt { background: var(--color-cream-d); }

  .pup-head {
    max-width: 640px;
    margin-bottom: 28px;
  }
  .pup-head h2 { color: var(--color-pine); margin: 0 0 8px; }
  .pup-sub {
    color: var(--color-muted);
    font-size: 0.95rem;
    line-height: 1.65;
    margin: 0;
  }
  .pup-partner {
    font-size: 0.9rem;
    font-style: italic;
    color: var(--color-muted);
    margin: 8px 0 0;
  }

  /* Current litter — same card design as the homepage's Available Puppies grid */
  .puppies-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 20px;
  }
  .puppy-card {
    background: var(--color-charcoal-bg);
    border-radius: 12px;
    overflow: hidden;
  }
  .puppy-card-photo {
    width: 100%;
    aspect-ratio: 3 / 4;
    overflow: hidden;
    background: var(--color-card);
  }
  .puppy-card-photo img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }
  .puppy-card-body {
    display: flex;
    flex-direction: column;
    gap: 8px;
    padding: 12px 14px;
  }
  .puppy-name {
    font-size: 0.85rem;
    font-weight: 700;
    color: var(--color-cream-d);
  }
  .puppy-collar {
    font-size: 0.7rem;
    color: rgba(247, 242, 231, 0.75);
    margin-top: -4px;
  }
  .puppy-badges {
    display: flex;
    align-items: center;
    gap: 6px;
    flex-wrap: wrap;
  }
  .puppy-sex {
    font-size: 0.65rem;
    text-transform: uppercase;
    letter-spacing: 0.07em;
    padding: 3px 9px;
    border-radius: 20px;
    font-weight: 700;
    background: rgba(255, 255, 255, 0.12);
    color: var(--color-cream-d);
    white-space: nowrap;
  }
  .litter-status {
    font-size: 0.65rem;
    text-transform: uppercase;
    letter-spacing: 0.07em;
    padding: 3px 9px;
    border-radius: 20px;
    font-weight: 700;
    white-space: nowrap;
  }
  .litter-status-available { background: #E1F5EE; color: #085041; }
  .litter-status-reserved  { background: #FAEEDA; color: #633806; }

  .pup-cta { margin-top: 28px; }
  .pup-empty { color: var(--color-muted); font-size: 1rem; margin: 0; }
  .pup-empty a { color: var(--color-pine); text-decoration: underline; }

  /* Planned — empty state */
  .pup-emptystate {
    border: 1.5px dashed rgba(0, 0, 0, 0.18);
    border-radius: 12px;
    padding: 36px 28px;
    text-align: center;
  }
  .pup-emptystate p {
    margin: 0;
    color: var(--color-muted);
    font-size: 1rem;
    line-height: 1.7;
  }
  .pup-emptystate a { color: var(--color-pine); text-decoration: underline; }

  /* Past litters — track-record list */
  .past-list {
    display: flex;
    flex-direction: column;
    gap: 16px;
    max-width: 760px;
  }
  .past-litter {
    background: var(--color-white);
    border: 1px solid var(--color-border-light);
    border-radius: 12px;
    padding: 22px 24px;
    box-shadow: 0 2px 16px rgba(0, 0, 0, 0.05);
  }
  .past-litter-head {
    display: flex;
    justify-content: space-between;
    align-items: baseline;
    gap: 16px;
    flex-wrap: wrap;
    margin-bottom: 8px;
  }
  .past-litter-parents {
    font-family: var(--font-display);
    font-size: 1.1rem;
    color: var(--color-pine);
    margin: 0;
  }
  .past-litter-date {
    font-size: 0.72rem;
    font-weight: 700;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    color: var(--color-brass);
    white-space: nowrap;
  }
  .past-litter-puppies {
    font-size: 0.95rem;
    color: var(--color-charcoal);
    line-height: 1.7;
    margin: 0;
  }
  .past-litter-retained {
    font-size: 0.85rem;
    font-style: italic;
    color: var(--color-muted);
    margin: 6px 0 0;
  }

  /* Waitlist band */
  .waitlist-band {
    background: var(--color-pine);
    padding: 64px 0;
  }
  .waitlist-inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 32px;
  }
  .waitlist-eyebrow { color: rgba(220, 229, 219, 0.5); margin-bottom: 6px; }
  .waitlist-heading { color: var(--color-card); margin: 0 0 8px; }
  .waitlist-body {
    color: rgba(237, 227, 208, 0.7);
    font-size: 0.93rem;
    margin: 0;
    max-width: 480px;
  }
  .waitlist-btn {
    flex-shrink: 0;
    color: var(--color-card);
    border-color: rgba(237, 227, 208, 0.45);
    white-space: nowrap;
  }
  .waitlist-btn:hover { border-color: var(--color-card); }

  @media (max-width: 900px) {
    .puppies-grid { grid-template-columns: repeat(2, 1fr); }
    .waitlist-inner { flex-direction: column; align-items: flex-start; }
  }
  @media (max-width: 640px) {
    .puppies-grid { grid-template-columns: 1fr; }
  }
</style>
