---
import Layout from '../layouts/Layout.astro';
import { getCollection } from 'astro:content';

const litters = (await getCollection('litters')).sort(
  (a, b) => new Date(b.data.birthdate).getTime() - new Date(a.data.birthdate).getTime()
);
const puppyEntries = await getCollection('puppies');

const activeLitter = litters.find(l => l.data.status === 'available' || l.data.status === 'reserved') ?? litters[0];
const litterPuppies = activeLitter
  ? puppyEntries
      .filter(p => p.data.litter === activeLitter.slug)
      .sort((a, b) => (a.data.order ?? 99) - (b.data.order ?? 99))
  : [];

function fmtDate(dateStr: string, opts?: Intl.DateTimeFormatOptions) {
  return new Date(dateStr + 'T12:00:00').toLocaleDateString('en-US', opts ?? { month: 'long', day: 'numeric', year: 'numeric' });
}
---
<Layout title="Puppies" description="Available and upcoming Australian Labradoodle puppies from Adams Farm Labradoodles in Greensboro, NC.">
  <div class="page-hero">
    <div class="container">
      <p class="eyebrow">Current &amp; upcoming litters</p>
      <h1>Available Puppies</h1>
      {activeLitter && (
        <p class="page-intro">
          {activeLitter.data.title} &middot; Born {fmtDate(activeLitter.data.birthdate, { month: 'long', day: 'numeric', year: 'numeric' })} &middot; Ready {fmtDate(activeLitter.data.readyDate, { month: 'long', day: 'numeric', year: 'numeric' })}
        </p>
      )}
    </div>
  </div>

  {activeLitter ? (
    <section class="section">
      <div class="container">

        <div class="litter-bar">
          <div class="litter-bar-info">
            <h2 class="litter-title">{activeLitter.data.title}</h2>
            <p class="litter-detail">Sire: {activeLitter.data.sire} &middot; Dam: {activeLitter.data.dam}</p>
          </div>
          <div class="litter-stats">
            {activeLitter.data.availableCount !== undefined && (
              <div class="litter-stat">
                <span class="stat-num">{activeLitter.data.availableCount}</span>
                <span class="stat-label">Available</span>
              </div>
            )}
            {activeLitter.data.puppyCount !== undefined && (
              <div class="litter-stat">
                <span class="stat-num">{activeLitter.data.puppyCount}</span>
                <span class="stat-label">In litter</span>
              </div>
            )}
            <div class="litter-stat">
              <span class="stat-num">{fmtDate(activeLitter.data.readyDate, { month: 'short', day: 'numeric' })}</span>
              <span class="stat-label">Go-home</span>
            </div>
          </div>
        </div>

        {litterPuppies.length > 0 && (
          <div class="puppy-grid">
            {litterPuppies.map(puppy => (
              <div class="puppy-card">
                <div class="puppy-photo-wrap">
                  <img
                    src={puppy.data.photo}
                    alt={`${puppy.data.name} — ${puppy.data.collar}`}
                    class="puppy-photo"
                    loading="lazy"
                  />
                  <span class={`puppy-badge status-${puppy.data.status}`}>
                    {puppy.data.status === 'available' ? 'Available' : 'Reserved'}
                  </span>
                </div>
                <div class="puppy-info">
                  <p class="puppy-name">{puppy.data.name}</p>
                  <p class="puppy-detail">{puppy.data.collar}{puppy.data.sex ? ` · ${puppy.data.sex}` : ''}</p>
                </div>
              </div>
            ))}
          </div>
        )}

        <div class="litter-note">
          <div>
            <p class="note-heading">Interested in an available puppy?</p>
            <p class="note-body">Fill out our contact form and we'll reach out to learn about your home and make sure it's a great match.</p>
          </div>
          <a href="/contact" class="btn btn-primary">Apply Now</a>
        </div>

      </div>
    </section>
  ) : (
    <section class="section container">
      <p class="empty-message">
        No litters listed right now — <a href="/contact">join the waitlist</a> and we'll reach out when one is announced.
      </p>
    </section>
  )}

  <section class="waitlist-band">
    <div class="container waitlist-inner">
      <div>
        <p class="eyebrow waitlist-eyebrow">Future litters</p>
        <h2 class="waitlist-heading">Join the Waitlist</h2>
        <p class="waitlist-body">Our litters fill quickly. Getting on the list early means first access to puppy picks from upcoming litters.</p>
      </div>
      <a href="/contact" class="btn btn-secondary waitlist-btn">Get on the list</a>
    </div>
  </section>
</Layout>

<style>
  .litter-bar {
    display: flex;
    justify-content: space-between;
    align-items: flex-start;
    gap: 32px;
    padding: 24px 28px;
    background: var(--color-card);
    border-radius: 10px;
    margin-bottom: 32px;
  }
  .litter-title { margin: 0 0 4px; font-size: 1.2rem; }
  .litter-detail { font-size: 0.85rem; color: var(--color-muted); margin: 0; }
  .litter-stats {
    display: flex;
    gap: 28px;
    flex-shrink: 0;
  }
  .litter-stat {
    display: flex;
    flex-direction: column;
    align-items: flex-end;
    text-align: right;
  }
  .stat-num {
    font-family: var(--font-display);
    font-size: 1.15rem;
    font-weight: 700;
    color: var(--color-pine);
    line-height: 1.1;
  }
  .stat-label {
    font-size: 0.7rem;
    text-transform: uppercase;
    letter-spacing: 0.07em;
    color: var(--color-muted);
    margin-top: 2px;
  }

  .puppy-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 20px;
    margin-bottom: 36px;
  }
  .puppy-card {
    background: var(--color-white);
    border: 1px solid var(--color-border);
    border-radius: 10px;
    overflow: hidden;
  }
  .puppy-photo-wrap { position: relative; }
  .puppy-photo {
    width: 100%;
    aspect-ratio: 1 / 1;
    object-fit: cover;
    display: block;
    background: var(--color-card);
  }
  .puppy-badge {
    position: absolute;
    top: 10px;
    left: 10px;
    font-size: 0.67rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.07em;
    padding: 4px 9px;
    border-radius: 12px;
  }
  .status-available { background: #E1F5EE; color: #085041; }
  .status-reserved  { background: #F1EFE8; color: #5A5650; }

  .puppy-info { padding: 12px 14px 14px; }
  .puppy-name {
    font-family: var(--font-display);
    font-size: 1rem;
    color: var(--color-pine);
    margin: 0 0 2px;
  }
  .puppy-detail { font-size: 0.8rem; color: var(--color-muted); margin: 0; }

  .litter-note {
    background: var(--color-cream);
    border: 1.5px solid var(--color-border);
    border-radius: 10px;
    padding: 24px 28px;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 24px;
  }
  .note-heading { font-weight: 700; font-size: 0.97rem; margin: 0 0 4px; color: var(--color-pine); }
  .note-body { font-size: 0.88rem; color: var(--color-muted); margin: 0; }

  .empty-message { color: var(--color-muted); margin-top: 24px; }
  .empty-message a { color: var(--color-pine); text-decoration: underline; }

  .waitlist-band {
    background: var(--color-pine);
    padding: 64px 0;
  }
  .waitlist-inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 32px;
  }
  .waitlist-eyebrow { color: rgba(247,242,231,0.5); margin-bottom: 6px; }
  .waitlist-heading { color: var(--color-cream); margin: 0 0 8px; }
  .waitlist-body {
    color: rgba(247,242,231,0.7);
    font-size: 0.93rem;
    margin: 0;
    max-width: 480px;
  }
  .waitlist-btn {
    flex-shrink: 0;
    color: var(--color-cream);
    border-color: rgba(247,242,231,0.45);
    white-space: nowrap;
  }
  .waitlist-btn:hover { border-color: var(--color-cream); }

  @media (max-width: 900px) {
    .litter-bar { flex-direction: column; gap: 16px; }
    .litter-stats { justify-content: flex-start; }
    .litter-stat { align-items: flex-start; text-align: left; }
    .puppy-grid { grid-template-columns: repeat(2, 1fr); }
    .waitlist-inner { flex-direction: column; align-items: flex-start; }
  }
  @media (max-width: 480px) {
    .puppy-grid { grid-template-columns: repeat(2, 1fr); gap: 12px; }
    .litter-note { flex-direction: column; align-items: flex-start; }
  }
</style>
