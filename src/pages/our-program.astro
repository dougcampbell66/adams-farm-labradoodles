---
import Layout from '../layouts/Layout.astro';

const included = [
  {
    title: 'PuppyQ Certification',
    body: 'Proof your puppy met the full standard: 10 events, 10 locations, 100 people.'
  },
  {
    title: 'PuppyQ Scorecard',
    body: 'Your puppy&rsquo;s seven-week snapshot, plus the eight-month follow-up that shows real growth.'
  },
  {
    title: 'PuppyQ History',
    body: 'A full record of your puppy&rsquo;s first weeks &mdash; every person, place, and milestone.'
  }
];
---
<Layout title="Our Program" description="The PuppyQ Framework &mdash; an evidence-based approach to raising calm, well-socialized Australian Labradoodle puppies.">

  <!-- HERO — AVSAB LEAD -->
  <div class="page-hero pq-hero">
    <div class="container">
      <h1 class="pq-lead">A puppy&rsquo;s most important weeks for meeting the world are its first three months. That&rsquo;s what we build around.</h1>
      <blockquote class="pq-hero-quote">&ldquo;The primary and most important time for puppy socialization is the first three months of life. During this time puppies should be exposed to as many new people, animals, stimuli and environments as can be achieved safely and without causing overstimulation.&rdquo;</blockquote>
      <p class="pq-hero-attr">&mdash; American Veterinary Society of Animal Behavior (AVSAB)</p>
      <a href="https://avsab.org/wp-content/uploads/2018/03/Puppy_Socialization_Position_Statement_Download_-_10-3-14.pdf" target="_blank" rel="noopener noreferrer" class="pq-hero-link">Read the full AVSAB position statement &rarr;</a>
    </div>
  </div>

  <!-- THE PUPPYQ FRAMEWORK -->
  <section class="section pq-sec-white">
    <div class="container pq-narrow">
      <h2>The PuppyQ Framework</h2>
      <p>PuppyQ is an evidence-based framework for raising calm, well-socialized puppies. Adams Farm raises each puppy following PuppyQ protocols and provides a PuppyQ Scorecard and History.</p>
    </div>
  </section>

  <!-- FOUR PERIODS -->
  <section class="section s-pq-stages">
    <div class="container">
      <h2>Four periods, birth to adulthood</h2>
      <p class="s-pq-stages-intro">PuppyQ organizes development into four periods. Each is a window of time when specific work happens.</p>
      <div class="s-pq-stages-grid">
        <div class="prog-card prog-card-green" tabindex="0">
          <div class="prog-card-inner">
            <div class="prog-face prog-face-front">
              <p class="prog-phase"><span class="prog-badge">1</span>Neonatal Period</p>
              <p class="prog-timeframe">Day 0–14</p>
              <p class="prog-front-body">Puppies are born blind and deaf, their brains not yet ready to learn.</p>
            </div>
            <div class="prog-face prog-face-back">
              <p class="prog-back-body">Every puppy is weighed and gently handled, one on one, every single day.</p>
            </div>
          </div>
        </div>
        <div class="prog-card prog-card-blue" tabindex="0">
          <div class="prog-card-inner">
            <div class="prog-face prog-face-front">
              <p class="prog-phase"><span class="prog-badge">2</span>Transition Period</p>
              <p class="prog-timeframe">Day 14–21</p>
              <p class="prog-front-body">Eyes and ears open and the puppy comes online for the first time.</p>
            </div>
            <div class="prog-face prog-face-back">
              <p class="prog-back-body">Handling stays calm and quiet while first impressions form.</p>
            </div>
          </div>
        </div>
        <div class="prog-card prog-card-yellow" tabindex="0">
          <div class="prog-card-inner">
            <div class="prog-face prog-face-front">
              <p class="prog-phase"><span class="prog-badge">3</span>Socialization Period</p>
              <p class="prog-timeframe">Week 3–12</p>
              <p class="prog-front-body">The critical window for meeting the world &mdash; and it stays open after your puppy comes home.</p>
            </div>
            <div class="prog-face prog-face-back">
              <p class="prog-back-body">Puppies meet people, places, and friendly dogs through steady, everyday exposure.</p>
            </div>
          </div>
        </div>
        <div class="prog-card prog-card-red" tabindex="0">
          <div class="prog-card-inner">
            <div class="prog-face prog-face-front">
              <p class="prog-phase"><span class="prog-badge">4</span>Juvenile Period</p>
              <p class="prog-timeframe">Week 12 to sexual maturity</p>
              <p class="prog-front-body">The socialization window has closed and your growing puppy enters adolescence.</p>
            </div>
            <div class="prog-face prog-face-back">
              <p class="prog-back-body">Keep up the outings and routines that carry the foundation forward.</p>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <script>
    document.querySelectorAll('.prog-card').forEach(card => {
      card.addEventListener('click', () => {
        if (window.matchMedia('(hover: none)').matches) {
          card.classList.toggle('is-flipped');
        }
      });
    });
  </script>

  <!-- EVIDENCE-BASED EARLY SOCIALIZATION -->
  <section class="section pq-sec-white">
    <div class="container pq-narrow">
      <h2>Evidence-based early socialization</h2>
      <p>PuppyQ Protocols follows the guidelines of the American Veterinary Society of Animal Behavior (AVSAB), which is supported and endorsed by the American Veterinary Medical Association (AVMA).</p>
    </div>
  </section>

  <!-- PUPPYQ SOCIALIZATION BENCHMARKS -->
  <section class="section pq-sec-cream">
    <div class="container pq-narrow">
      <h2>PuppyQ Socialization Benchmarks</h2>
      <p>Dr. Ian Dunbar is a veterinarian and animal behaviorist who holds a veterinary degree from the Royal Veterinary College in London and a doctorate in animal behavior from UC Berkeley. In 1982, he founded SIRIUS&reg; Puppy Training, the world&rsquo;s first off-leash puppy socialization program, and went on to found the Association of Professional Dog Trainers, now the largest dog trainer organization in the world. His socialization benchmark is one of the most widely cited in the field &mdash; not because it&rsquo;s official policy from any single body, but because decades of trainers, behaviorists, and veterinarians have converged on it independently.</p>
      <p>Our socialization goal follows his two-part benchmark: 100 people by 8 weeks with us, and 100 more in the first month home with you. It&rsquo;s a shared effort &mdash; we lay the foundation during your puppy&rsquo;s first weeks, and you carry it forward through the most formative days of their life.</p>
      <p>To earn PuppyQ Certification, each puppy meets a clear standard by 8 weeks: 10 events, 10 locations, and 100 people. It&rsquo;s a floor we hold ourselves to for every single puppy.</p>
    </div>
  </section>

  <!-- PULL-QUOTE BREAK -->
  <section class="s-break">
    <div class="container s-break-inner">
      <blockquote class="break-quote">
        &ldquo;Prevention is better than intervention.&rdquo;
        <cite class="break-cite">&mdash; Dr. Ian Dunbar</cite>
      </blockquote>
    </div>
  </section>

  <!-- Q IS FOR QUOTIENT -->
  <section class="section pq-sec-dark">
    <div class="container pq-narrow">
      <h2>PuppyQ &ndash; Q is for Quotient</h2>
      <p>Q stands for Quotient. We track thirteen of them, using C-BARQ &mdash; a validated behavior assessment from the University of Pennsylvania. It measures things like trainability, energy, and how your puppy responds to new people, dogs, and situations.</p>
      <p>C-BARQ &mdash; the Canine Behavioral Assessment and Research Questionnaire &mdash; was developed at the University of Pennsylvania by Dr. James Serpell and Dr. Yuying Hsu in 2003, to give owners and researchers a standardized way to measure real canine behavior. It&rsquo;s since been used in tens of thousands of evaluations worldwide. PuppyQ provides this evaluation to all forever families to help measure and improve its protocols.</p>
      <p>In conjunction with C-BARQ, PuppyQ has also developed its own Q Assessment, given to puppies at seven weeks by our certified ambassadors, before the puppy goes to its forever home. The Q Assessment is not used as a predictor of behavior, but as a look at the puppy&rsquo;s early traits and temperament.</p>
    </div>
  </section>

  <!-- WHAT EVERY PUPPY GOES HOME WITH -->
  <section class="section s-pq-included">
    <div class="container">
      <h2>What every puppy goes home with</h2>
      <p class="pq-included-intro">Every Adams Farm puppy comes home with three things:</p>
      <div class="s-pq-included-grid">
        {included.map(item => (
          <div class="pq-included-card">
            <h3 class="pq-included-title">{item.title}</h3>
            <p class="pq-included-body" set:html={item.body} />
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- CLOSING CTA -->
  <section class="s-pq-cta">
    <div class="container s-pq-cta-inner">
      <h2 class="s-pq-cta-heading">See our current puppies</h2>
      <a href="/puppies" class="btn btn-primary">See available puppies</a>
    </div>
  </section>

</Layout>

<style>
  /* ─── HERO ───────────────────────────────────────────────────── */
  .pq-lead {
    font-size: clamp(1.35rem, 2.4vw, 1.7rem);
    font-weight: 400;
    line-height: 1.35;
    max-width: 720px;
    margin: 0;
  }
  .pq-hero-quote {
    margin: 28px 0 0;
    font-family: var(--font-display);
    font-style: italic;
    font-size: clamp(1.55rem, 3.2vw, 2.25rem);
    line-height: 1.4;
    color: var(--color-card);
    max-width: 820px;
  }
  .pq-hero-attr {
    margin: 16px 0 0;
    font-size: 0.85rem;
    font-weight: 700;
    letter-spacing: 0.04em;
    color: rgba(220, 229, 219, 0.6);
  }
  .pq-hero-link {
    display: inline-block;
    margin: 20px 0 0;
    font-size: 0.9rem;
    font-weight: 700;
    color: var(--color-brass);
    text-decoration: none;
    border-bottom: 1.5px solid var(--color-brass);
    padding-bottom: 2px;
  }

  /* ─── PROSE SECTIONS ─────────────────────────────────────────── */
  .pq-sec-white { background: var(--color-white); }
  .pq-sec-cream { background: var(--color-cream-d); }
  .pq-narrow { max-width: 720px; }
  .pq-narrow h2 { color: var(--color-pine); margin: 0 0 16px; }
  .pq-narrow p {
    color: var(--color-charcoal);
    font-size: 1rem;
    line-height: 1.78;
    margin: 0 0 16px;
  }
  .pq-narrow p:last-child { margin-bottom: 0; }
  .pq-quote {
    margin: 8px 0 20px;
    padding: 20px 24px;
    border-left: 3px solid var(--color-brass);
    font-family: var(--font-display);
    font-style: italic;
    font-size: 1.15rem;
    color: var(--color-charcoal);
    line-height: 1.55;
  }
  .pq-link {
    display: inline-block;
    margin: 0 0 20px;
    font-size: 0.9rem;
    font-weight: 700;
    color: var(--color-pine);
    text-decoration: none;
    border-bottom: 1.5px solid var(--color-brass);
    padding-bottom: 2px;
  }
  /* pull-quote break (mirrors the homepage's .s-break) */
  .s-break {
    background: var(--color-pine);
    padding: 80px 0;
  }
  .s-break-inner { text-align: center; max-width: 680px; margin: 0 auto; }
  .break-quote {
    margin: 0;
    font-family: var(--font-display);
    font-style: italic;
    font-size: clamp(1.5rem, 3vw, 2.1rem);
    color: var(--color-card);
    line-height: 1.55;
  }
  .break-cite {
    display: block;
    font-style: normal;
    font-family: var(--font-body);
    font-size: 0.8rem;
    letter-spacing: 0.06em;
    color: rgba(220, 229, 219, 0.55);
    margin-top: 20px;
  }

  /* dark-background prose variant (light text on charcoal) */
  .pq-sec-dark {
    background: var(--color-charcoal-bg);
    border-top: 1px solid var(--color-border-dark);
  }
  .pq-sec-dark .pq-narrow h2 { color: var(--color-card); }
  .pq-sec-dark .pq-narrow p { color: rgba(237, 227, 208, 0.8); }
  .pq-sec-dark .pq-quote { color: var(--color-card); }
  .pq-sec-dark .pq-link { color: var(--color-brass); }

  /* ─── FOUR PERIODS ───────────────────────────────────────────── */
  .s-pq-stages {
    background: var(--color-charcoal-bg);
    border-top: 1px solid var(--color-border-dark);
  }
  .s-pq-stages h2 { color: var(--color-card); margin: 0 0 12px; }
  .s-pq-stages-intro {
    color: rgba(237, 227, 208, 0.75);
    font-size: 1rem;
    line-height: 1.72;
    max-width: 620px;
    margin: 0 0 40px;
  }
  .s-pq-stages-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 20px;
  }
  /* flip cards (copied from the home page PuppyQ section) */
  .prog-card {
    perspective: 1000px;
    height: 260px;
    cursor: pointer;
    outline: none;
  }
  .prog-card:focus-visible {
    border-radius: 12px;
    outline: 2px solid var(--color-pine);
    outline-offset: 3px;
  }
  .prog-card-inner {
    position: relative;
    width: 100%;
    height: 100%;
    transform-style: preserve-3d;
    transition: transform 0.5s ease;
  }
  .prog-card:hover .prog-card-inner,
  .prog-card:focus .prog-card-inner,
  .prog-card.is-flipped .prog-card-inner {
    transform: rotateY(180deg);
  }
  .prog-face {
    position: absolute;
    inset: 0;
    backface-visibility: hidden;
    border-radius: 12px;
    padding: 28px;
    overflow: hidden;
  }
  .prog-face-front {
    background: var(--color-white);
    border: 1px solid var(--color-border-light);
    box-shadow: 0 2px 16px rgba(0,0,0,0.07);
    display: flex;
    flex-direction: column;
    justify-content: center;
    gap: 10px;
  }
  .prog-card-green  .prog-face-front { border-top: 4px solid var(--color-focus-green); }
  .prog-card-blue   .prog-face-front { border-top: 4px solid var(--color-calm-blue); }
  .prog-card-yellow .prog-face-front { border-top: 4px solid var(--color-excite-yellow); }
  .prog-card-red    .prog-face-front { border-top: 4px solid var(--color-feelings-red); }
  .prog-face-back {
    transform: rotateY(180deg);
    display: flex;
    align-items: center;
    justify-content: center;
    text-align: center;
  }
  .prog-card-green  .prog-face-back { background: var(--color-focus-green); }
  .prog-card-blue   .prog-face-back { background: var(--color-calm-blue); }
  .prog-card-yellow .prog-face-back { background: var(--color-excite-yellow); }
  .prog-card-red    .prog-face-back { background: var(--color-feelings-red); }
  .prog-back-body {
    font-size: 0.875rem;
    line-height: 1.65;
    margin: 0;
    color: #fff;
  }
  .prog-card-yellow .prog-back-body { color: var(--color-pine); }
  .prog-phase {
    font-size: 0.7rem;
    font-weight: 700;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    display: flex;
    align-items: center;
    gap: 8px;
    margin: 0;
  }
  .prog-card-green  .prog-phase { color: var(--color-focus-green); }
  .prog-card-blue   .prog-phase { color: var(--color-calm-blue); }
  .prog-card-yellow .prog-phase { color: #B8921E; }
  .prog-card-red    .prog-phase { color: var(--color-feelings-red); }
  .prog-badge {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 24px;
    height: 24px;
    border-radius: 50%;
    font-size: 0.68rem;
    font-weight: 700;
    color: #fff;
    flex-shrink: 0;
    text-transform: none;
    letter-spacing: 0;
  }
  .prog-card-green  .prog-badge { background: var(--color-focus-green); }
  .prog-card-blue   .prog-badge { background: var(--color-calm-blue); }
  .prog-card-yellow .prog-badge { background: var(--color-excite-yellow); color: var(--color-pine); }
  .prog-card-red    .prog-badge { background: var(--color-feelings-red); }
  .prog-timeframe {
    font-size: 0.7rem;
    font-weight: 600;
    letter-spacing: 0.05em;
    color: var(--color-muted);
    margin: 0;
  }
  .prog-front-body {
    font-size: 0.78rem;
    color: var(--color-muted);
    line-height: 1.6;
    margin: 0;
  }
  @media (prefers-reduced-motion: reduce) {
    .prog-card-inner { transform: none !important; transition: none; }
    .prog-face { backface-visibility: visible; }
    .prog-face-front { transition: opacity 0.3s; z-index: 1; }
    .prog-face-back  { transform: none; opacity: 0; transition: opacity 0.3s; z-index: 2; }
    .prog-card:hover .prog-face-front,
    .prog-card:focus  .prog-face-front,
    .prog-card.is-flipped .prog-face-front { opacity: 0; }
    .prog-card:hover .prog-face-back,
    .prog-card:focus  .prog-face-back,
    .prog-card.is-flipped .prog-face-back  { opacity: 1; }
  }

  /* ─── WHAT EVERY PUPPY GOES HOME WITH ──────────────────────────── */
  .s-pq-included { background: var(--color-white); }
  .s-pq-included h2 { color: var(--color-pine); margin: 0 0 14px; }
  .pq-included-intro {
    color: var(--color-charcoal);
    font-size: 1rem;
    line-height: 1.78;
    max-width: 640px;
    margin: 0 0 28px;
  }
  .s-pq-included-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 20px;
  }
  .pq-included-card {
    background: var(--color-white);
    border: 1px solid var(--color-border-light);
    border-radius: 12px;
    padding: 28px;
    box-shadow: 0 2px 16px rgba(0, 0, 0, 0.07);
  }
  .pq-included-title {
    font-family: var(--font-display);
    font-size: 1.1rem;
    color: var(--color-pine);
    line-height: 1.3;
    margin: 0 0 10px;
  }
  .pq-included-body {
    font-size: 0.9rem;
    color: var(--color-muted);
    line-height: 1.72;
    margin: 0;
  }

  /* ─── CLOSING CTA ──────────────────────────────────────────────── */
  .s-pq-cta {
    background: var(--color-charcoal-bg);
    border-top: 1px solid var(--color-border-dark);
    padding: 72px 0;
  }
  .s-pq-cta-inner {
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
    gap: 24px;
  }
  .s-pq-cta-heading { color: var(--color-card); margin: 0; }
  .s-pq-cta .btn-primary {
    background: var(--color-brass);
    color: var(--color-charcoal);
    border-color: transparent;
  }
  .s-pq-cta .btn-primary:hover { filter: brightness(0.9); }

  /* ─── RESPONSIVE ───────────────────────────────────────────────── */
  @media (max-width: 900px) {
    .s-pq-stages-grid   { grid-template-columns: 1fr 1fr; }
    .s-pq-included-grid { grid-template-columns: 1fr; }
  }
  @media (max-width: 640px) {
    .s-pq-stages-grid { grid-template-columns: 1fr; }
  }
</style>
