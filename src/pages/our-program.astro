---
import Layout from '../layouts/Layout.astro';

const stages = [
  {
    color: 'green',
    num: '1',
    stage: 'Stage 1',
    timeframe: 'Day 0&ndash;21',
    body: 'Every puppy is weighed daily, handled daily, and returned to its mother promptly. There&rsquo;s no behavior to measure yet &mdash; eyes and ears are still closed. This is the foundation, not the training.'
  },
  {
    color: 'blue',
    num: '2',
    stage: 'Stage 2',
    timeframe: 'Week 3&ndash;6',
    body: 'The socialization window opens. Every puppy gets individual time &mdash; taken out on its own, not worked as a litter. Puppies start going outdoors around four weeks, once they can regulate their own body temperature.'
  },
  {
    color: 'yellow',
    num: '3',
    stage: 'Stage 3',
    timeframe: 'Week 6&ndash;Go-Home',
    body: 'Meeting the world, on purpose. Our floor: 10 events, 10 locations, 100 people, by 8 weeks &mdash; the breeder&rsquo;s half of Dr. Ian Dunbar&rsquo;s benchmark for early socialization.'
  },
  {
    color: 'red',
    num: '4',
    stage: 'Stage 4',
    timeframe: 'Go-Home&ndash;12 Months',
    body: 'This stage belongs to your family. The socialization window closes at 12&ndash;14 weeks &mdash; just a few weeks after you bring your puppy home &mdash; so what happens right after go-home matters as much as everything before it.'
  }
];

const included = [
  {
    title: 'PuppyQ Certification',
    body: 'Proof every puppy met the standard: 10 events, 10 locations, 100 people, by 8 weeks.'
  },
  {
    title: 'PuppyQ Scorecard',
    body: 'A snapshot of your puppy&rsquo;s temperament at seven weeks. This is not a prediction of your adult dog &mdash; what your puppy becomes depends substantially on what happens next, with you.'
  },
  {
    title: 'PuppyQ History',
    body: 'A full record of your puppy&rsquo;s first weeks: every event, every place, every person.'
  }
];
---
<Layout title="Our Program" description="PuppyQ &mdash; an evidence-based framework for raising calm puppies, built on individual time and early exposure to the world.">

  <!-- SECTION 1 — HERO / INTRO -->
  <div class="page-hero pq-hero">
    <div class="container">
      <p class="eyebrow">Our Program</p>
      <h1>PuppyQ</h1>
      <p class="pq-subhead">An evidence-based framework for raising calm puppies.</p>
      <p class="pq-hero-body">PuppyQ is built on two things the research actually supports: individual time with each puppy, and early exposure to the world. Every claim behind it is rated for how strong the evidence really is &mdash; because most of what breeders repeat about early puppy development turns out to be folklore, not science.</p>
    </div>
  </div>

  <!-- SECTION 2 — WHAT WE DON'T DO -->
  <section class="section s-pq-diff">
    <div class="container s-pq-narrow">
      <p class="eyebrow">The difference</p>
      <h2>We checked the industry standard. Most of it didn&rsquo;t hold up.</h2>
      <p class="s-pq-body">Early Neurological Stimulation. Early Scent Introduction. Puppy aptitude testing at seven weeks. These are the three most common practices in puppy-raising, and none of them have the evidence behind them that gets claimed. PuppyQ doesn&rsquo;t use any of them &mdash; not because they&rsquo;re harmful, but because every minute spent on an unproven exercise is a minute not spent on something that actually works: individual handling, and getting puppies out into the world early.</p>
    </div>
  </section>

  <!-- SECTION 3 — THE FOUR STAGES -->
  <section class="section s-pq-stages">
    <div class="container">
      <h2>Four Stages</h2>
      <p class="s-pq-stages-intro">The stages are time &mdash; nothing more. Not personality types. A calendar.</p>
      <div class="s-pq-stages-grid">
        {stages.map(s => (
          <div class={`pq-stage pq-stage-${s.color}`}>
            <p class="pq-stage-label">
              <span class="pq-stage-badge">{s.num}</span>{s.stage}
            </p>
            <p class="pq-stage-time" set:html={s.timeframe} />
            <p class="pq-stage-body" set:html={s.body} />
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- SECTION 4 — THE STANDARD, EXPLAINED CORRECTLY -->
  <section class="s-pq-standard">
    <div class="container s-pq-standard-inner">
      <p class="eyebrow pq-standard-eyebrow">The standard</p>
      <h2 class="pq-standard-heading">Where &ldquo;100 people&rdquo; actually comes from</h2>
      <p class="pq-standard-body">Dr. Ian Dunbar&rsquo;s real recommendation is two hundred people, not one hundred: at least 100 before 8 weeks, met by the breeder, and another 100 during the first month home, met by the family. We meet our half. Your first month with your puppy is when you meet yours.</p>
    </div>
  </section>

  <!-- SECTION 5 — WHAT EVERY PUPPY GOES HOME WITH -->
  <section class="section s-pq-included">
    <div class="container">
      <p class="eyebrow">Included with every puppy</p>
      <h2>What your puppy comes home with</h2>
      <div class="s-pq-included-grid">
        {included.map(item => (
          <div class="pq-included-card">
            <h3 class="pq-included-title">{item.title}</h3>
            <p class="pq-included-body" set:html={item.body} />
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- SECTION 6 — CLOSING CTA -->
  <section class="s-pq-cta">
    <div class="container s-pq-cta-inner">
      <h2 class="s-pq-cta-heading">See our current puppies</h2>
      <a href="/puppies" class="btn btn-primary">See available puppies</a>
    </div>
  </section>

</Layout>

<style>
  /* ─── SECTION 1 — HERO / INTRO ──────────────────────────────── */
  .pq-subhead {
    font-family: var(--font-display);
    font-size: clamp(1.15rem, 2.4vw, 1.4rem);
    color: var(--color-card);
    margin: 14px 0 0;
    line-height: 1.4;
    max-width: 620px;
  }
  .pq-hero-body {
    color: rgba(237, 227, 208, 0.75);
    max-width: 640px;
    margin: 20px 0 0;
    font-size: 1rem;
    line-height: 1.72;
  }

  /* ─── SHARED ────────────────────────────────────────────────── */
  .s-pq-narrow { max-width: 720px; }
  .s-pq-body {
    color: var(--color-charcoal);
    line-height: 1.78;
    margin: 0;
    font-size: 1rem;
  }
  .s-pq-diff .eyebrow { margin-bottom: var(--space-eyebrow-gap); }
  .s-pq-diff h2 { color: var(--color-pine); margin: 0 0 16px; }

  /* ─── SECTION 2 — WHAT WE DON'T DO ─────────────────────────── */
  .s-pq-diff { background: var(--color-white); }

  /* ─── SECTION 3 — THE FOUR STAGES ──────────────────────────── */
  .s-pq-stages {
    background: var(--color-charcoal-bg);
    border-top: 1px solid var(--color-border-dark);
  }
  .s-pq-stages h2 { color: var(--color-card); margin: 0 0 12px; }
  .s-pq-stages-intro {
    color: rgba(237, 227, 208, 0.75);
    font-size: 1rem;
    line-height: 1.72;
    max-width: 620px;
    margin: 0 0 40px;
  }
  .s-pq-stages-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 20px;
  }
  .pq-stage {
    background: var(--color-white);
    border: 1px solid var(--color-border-light);
    border-radius: 12px;
    box-shadow: 0 2px 16px rgba(0, 0, 0, 0.07);
    padding: 28px;
    display: flex;
    flex-direction: column;
    gap: 10px;
  }
  .pq-stage-green  { border-top: 4px solid var(--color-focus-green); }
  .pq-stage-blue   { border-top: 4px solid var(--color-calm-blue); }
  .pq-stage-yellow { border-top: 4px solid var(--color-excite-yellow); }
  .pq-stage-red    { border-top: 4px solid var(--color-feelings-red); }

  .pq-stage-label {
    font-size: 0.7rem;
    font-weight: 700;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    display: flex;
    align-items: center;
    gap: 8px;
    margin: 0;
  }
  .pq-stage-green  .pq-stage-label { color: var(--color-focus-green); }
  .pq-stage-blue   .pq-stage-label { color: var(--color-calm-blue); }
  .pq-stage-yellow .pq-stage-label { color: #B8921E; }
  .pq-stage-red    .pq-stage-label { color: var(--color-feelings-red); }

  .pq-stage-badge {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 24px;
    height: 24px;
    border-radius: 50%;
    font-size: 0.68rem;
    font-weight: 700;
    color: #fff;
    flex-shrink: 0;
    text-transform: none;
    letter-spacing: 0;
  }
  .pq-stage-green  .pq-stage-badge { background: var(--color-focus-green); }
  .pq-stage-blue   .pq-stage-badge { background: var(--color-calm-blue); }
  .pq-stage-yellow .pq-stage-badge { background: var(--color-excite-yellow); color: var(--color-pine); }
  .pq-stage-red    .pq-stage-badge { background: var(--color-feelings-red); }

  .pq-stage-time {
    font-family: var(--font-display);
    font-size: 1.05rem;
    color: var(--color-pine);
    line-height: 1.3;
    margin: 0;
  }
  .pq-stage-body {
    font-size: 0.875rem;
    color: var(--color-muted);
    line-height: 1.72;
    margin: 0;
  }

  /* ─── SECTION 4 — THE STANDARD, EXPLAINED ──────────────────── */
  .s-pq-standard {
    background: var(--color-pine);
    padding: 64px 0;
  }
  .s-pq-standard-inner { max-width: 640px; }
  .pq-standard-eyebrow { color: rgba(220, 229, 219, 0.5); margin-bottom: 8px; }
  .pq-standard-heading { color: var(--color-card); margin: 0 0 14px; }
  .pq-standard-body {
    color: rgba(220, 229, 219, 0.8);
    line-height: 1.72;
    font-size: 1rem;
    margin: 0;
  }

  /* ─── SECTION 5 — GOES HOME WITH ───────────────────────────── */
  .s-pq-included { background: var(--color-white); }
  .s-pq-included .eyebrow { margin-bottom: var(--space-eyebrow-gap); }
  .s-pq-included h2 { color: var(--color-pine); margin: 0 0 32px; }
  .s-pq-included-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 20px;
  }
  .pq-included-card {
    background: var(--color-white);
    border: 1px solid var(--color-border-light);
    border-radius: 12px;
    padding: 28px;
    box-shadow: 0 2px 16px rgba(0, 0, 0, 0.07);
  }
  .pq-included-title {
    font-family: var(--font-display);
    font-size: 1.1rem;
    color: var(--color-pine);
    line-height: 1.3;
    margin: 0 0 10px;
  }
  .pq-included-body {
    font-size: 0.9rem;
    color: var(--color-muted);
    line-height: 1.72;
    margin: 0;
  }

  /* ─── SECTION 6 — CLOSING CTA ──────────────────────────────── */
  .s-pq-cta {
    background: var(--color-charcoal-bg);
    border-top: 1px solid var(--color-border-dark);
    padding: 72px 0;
  }
  .s-pq-cta-inner {
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
    gap: 24px;
  }
  .s-pq-cta-heading { color: var(--color-card); margin: 0; }
  .s-pq-cta .btn-primary {
    background: var(--color-brass);
    color: var(--color-charcoal);
    border-color: transparent;
  }
  .s-pq-cta .btn-primary:hover { filter: brightness(0.9); }

  /* ─── RESPONSIVE ───────────────────────────────────────────── */
  @media (max-width: 900px) {
    .s-pq-stages-grid   { grid-template-columns: 1fr 1fr; }
    .s-pq-included-grid { grid-template-columns: 1fr; }
  }
  @media (max-width: 640px) {
    .s-pq-stages-grid { grid-template-columns: 1fr; }
  }
</style>
