---
---
<footer>
  <div class="container footer-inner">

    <div class="footer-col">
      <p class="footer-heading">Adams Farm Labradoodles</p>
      <nav class="footer-nav">
        <a href="/">Home</a>
        <a href="/our-dogs">Our dogs</a>
        <a href="/our-program">Our program</a>
        <a href="/guardians">Guardians</a>
        <a href="/puppies">Puppies</a>
        <a href="/testimonials">Testimonials</a>
        <a href="/faq">FAQ</a>
      </nav>
    </div>

    <div class="footer-col">
      <p class="footer-heading">Get a puppy</p>
      <nav class="footer-nav">
        <a href="/puppies">See available puppies</a>
        <a href="/contact">Join the waitlist</a>
        <a href="/our-dogs">Meet the parents</a>
        <a href="/our-program">Our health guarantee</a>
      </nav>
    </div>

    <div class="footer-col">
      <p class="footer-heading">Contact &amp; location</p>
      <p class="footer-detail">Greensboro, NC</p>
      <p class="footer-detail"><a href="/contact">Send us a message</a></p>

      <div class="alaa-badge-slot">
        <img src="/images/credentials/Adams-Farm-ALAA-Logo-2026.png" alt="ALAA Member 2026" class="alaa-badge-img" />
      </div>
    </div>

  </div>

  <div class="footer-bottom">
    <div class="container footer-bottom-inner">
      <p>&copy; {new Date().getFullYear()} Adams Farm Labradoodles &middot; Greensboro, NC</p>
    </div>
  </div>
</footer>

<style>
  footer {
    border-top: 1px solid var(--color-border-dark);
    margin-top: 0;
    background: var(--color-charcoal-bg);
  }
  .footer-inner {
    display: grid;
    grid-template-columns: 1.2fr 1fr 1fr;
    gap: 48px;
    padding-top: 48px;
    padding-bottom: 40px;
  }
  .footer-heading {
    font-family: var(--font-display);
    font-size: 0.85rem;
    font-weight: 700;
    color: var(--color-cream-d);
    margin: 0 0 14px;
    letter-spacing: 0.02em;
  }
  .footer-nav {
    display: flex;
    flex-direction: column;
    gap: 8px;
  }
  .footer-nav a {
    font-size: 0.85rem;
    color: rgba(247, 242, 231, 0.75);
    text-decoration: none;
    transition: color 0.15s;
  }
  .footer-nav a:hover {
    color: var(--color-cream-d);
  }
  .footer-detail {
    font-size: 0.85rem;
    color: rgba(247, 242, 231, 0.75);
    margin: 0 0 6px;
  }
  .footer-detail a {
    color: rgba(247, 242, 231, 0.75);
    text-decoration: underline;
  }
  .footer-detail a:hover {
    color: var(--color-cream-d);
  }
  .alaa-badge-slot {
    margin-top: 20px;
  }
  .alaa-badge-img {
    width: 88px;
    height: auto;
    display: block;
  }
  .footer-bottom {
    border-top: 1px solid var(--color-border-dark);
    padding: 16px 0;
  }
  .footer-bottom-inner {
    font-size: 0.75rem;
    color: rgba(247, 242, 231, 0.6);
  }
  .footer-bottom-inner p {
    margin: 0;
  }

  @media (max-width: 768px) {
    .footer-inner {
      grid-template-columns: 1fr 1fr;
      gap: 32px;
    }
    .footer-col:first-child {
      grid-column: 1 / -1;
    }
  }
  @media (max-width: 480px) {
    .footer-inner {
      grid-template-columns: 1fr;
    }
    .footer-col:first-child {
      grid-column: auto;
    }
  }
</style>
